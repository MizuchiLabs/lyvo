{
	"name": "@mizuchilabs/lyvo",
	"version": "0.2.0",
	"description": "Documentation theme with Astro",
	"keywords": [
		"astro",
		"astro-template",
		"astro-theme",
		"docs",
		"documentation"
	],
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MizuchiLabs/lyvo.git",
		"directory": "packages/lyvo"
	},
	"type": "module",
	"exports": {
		".": "./src/integration.ts",
		"./components/base/*": "./src/components/base/*",
		"./components/docs/*": "./src/components/docs/*",
		"./components/openapi/*": "./src/components/openapi/*",
		"./layouts/*": "./src/layouts/*",
		"./collections": "./src/lib/collections.ts",
		"./schema": "./src/schema.ts",
		"./style.css": "./src/styles/global.css",
		"./routes/*": "./src/routes/*",
		"./types": "./types.d.ts"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "oxlint --fix",
		"format": "prettier --write ."
	},
	"dependencies": {
		"@apidevtools/swagger-parser": "^12.1.0",
		"@astrojs/language-server": "^2.16.10",
		"@astrojs/markdown-remark": "^7.2.0",
		"@astrojs/mdx": "^6.0.2",
		"@astrojs/sitemap": "^3.7.3",
		"@lucide/astro": "^1.17.0",
		"@tailwindcss/typography": "^0.5.20",
		"astro-pagefind": "^2.0.0",
		"clsx": "^2.1.1",
		"marked": "^18.0.5",
		"openapi-sampler": "^1.7.4",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.2",
		"astro": "^6.4.4",
		"oxlint": "^1.69.0",
		"prettier": "3.8.5",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"sharp": "^0.35.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@pagefind/component-ui": "^1.5.0",
		"@tailwindcss/vite": "^4.0.0",
		"astro": "^6.4.0",
		"tailwindcss": "^4.0.0"
	}
}
