{
  "name": "@mizuchilabs/lyvo",
  "version": "0.1.5",
  "description": "Documentation theme with Astro",
  "keywords": [
    "astro",
    "astro-template",
    "astro-theme",
    "docs",
    "documentation"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/integration.ts",
    "./components/base/*": "./src/components/base/*",
    "./components/docs/*": "./src/components/docs/*",
    "./components/openapi/*": "./src/components/openapi/*",
    "./layouts/*": "./src/layouts/*",
    "./schema": "./src/schema.ts",
    "./style.css": "./src/styles/global.css",
    "./routes/*": "./src/routes/*",
    "./types": "./types.d.ts"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.2",
    "@lucide/astro": "^1.16.0",
    "openapi-sampler": "^1.7.3",
    "pagefind": "^1.5.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "shadcn": "^4.7.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "astro": "^6.3.3",
    "clsx": "^2.1.1",
    "oxlint": "^1.65.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vite-plugin-svgr": "^5.2.0"
  },
  "peerDependencies": {
    "@astrojs/mdx": "^4.0.0 || ^5.0.0",
    "@tailwindcss/typography": "^0.5.0",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.0.0 || ^6.0.0",
    "tailwindcss": "^4.0.0"
  }
}
