---
import Search from '@lyvo/components/base/Search.astro';
import Sidebar from '@lyvo/components/docs/Sidebar.astro';
import MobileToC from '@lyvo/components/docs/MobileToC.astro';
import ThemeToggle from '@lyvo/components/base/ThemeToggle.astro';
import BaseHead from '@lyvo/layouts/BaseHead.astro';
import ToC from '@lyvo/components/docs/ToC.astro';
import Breadcrumbs from '@lyvo/components/docs/Breadcrumbs.astro';
import PageHeader from '@lyvo/components/docs/PageHeader.astro';
import Pagination from '@lyvo/components/docs/Pagination.astro';
import fs from 'node:fs';
import child_process from 'node:child_process';
import util from 'node:util';
import { cn } from '@lyvo/lib/utils';
import config from 'virtual:lyvo-config';

interface Props {
	title: string;
	description?: string;
	headings?: { depth: number; slug: string; text: string }[];
	entry?: any;
	isApi?: boolean;
}

const { title, description, headings = [], entry, isApi = false } = Astro.props;

const execAsync = util.promisify(child_process.exec);

const gitDateCache = new Map<string, string>();

const lastUpdated = async () => {
	if (!entry?.filePath) return '';

	const cached = gitDateCache.get(entry.filePath);
	if (cached !== undefined) return cached;

	try {
		const { stdout } = await execAsync(`git log -1 --format="%ct" -- "${entry.filePath}"`);
		const gitTime = stdout.toString().trim();
		if (gitTime) {
			const formatted = new Intl.DateTimeFormat(undefined, {
				month: 'short',
				day: 'numeric',
				year: 'numeric'
			}).format(new Date(parseInt(gitTime) * 1000));
			gitDateCache.set(entry.filePath, formatted);
			return formatted;
		}
	} catch (e) {
		// Fallback to fs.statSync if git fails
	}

	try {
		const stats = fs.statSync(entry.filePath);
		const formatted = new Intl.DateTimeFormat(undefined, {
			month: 'short',
			day: 'numeric',
			year: 'numeric'
		}).format(stats.mtime);
		gitDateCache.set(entry.filePath, formatted);
		return formatted;
	} catch (e) {
		return '';
	}
};

const lastUpdatedText = await lastUpdated();
---

<!doctype html>
<html lang={config.lang ?? 'en'} class="scroll-smooth">
	<BaseHead title={title} description={description} />

	<body
		class="flex h-screen w-full flex-col overflow-hidden bg-sidebar font-sans text-foreground antialiased md:flex-row"
	>
		<Sidebar />

		{/* Main Content */}
		<div class="flex h-full flex-1 flex-col overflow-hidden md:rounded-xl md:py-3 md:pr-3">
			<main
				id="main-scroll-area"
				class="no-scrollbar relative flex-1 overflow-y-auto bg-background md:rounded-xl md:border md:border-r-0 md:border-border/40 md:shadow-sm"
			>
				{/* Header */}
				<div
					class="sticky top-0 z-30 flex h-14 items-center justify-between gap-4 border-b border-border/40 bg-sidebar/50 px-6 backdrop-blur-md md:rounded-t-xl"
				>
					<Breadcrumbs title={title} />
					{!isApi && <MobileToC headings={headings} title={title} />}
					<div class="flex items-center gap-3">
						<Search />
						<ThemeToggle transition:persist />
					</div>
				</div>

				{/* Content Wrapper */}
				<div
					class={cn(
						'mx-auto flex w-full flex-col',
						!isApi && 'max-w-5xl px-4 sm:px-6 md:px-8 xl:flex-row xl:gap-12'
					)}
				>
					<div
						class={cn(
							'mx-auto w-full min-w-0 flex-1',
							!isApi && 'px-4 py-8 sm:px-6 md:px-8'
						)}
					>
						{
							!isApi && (
								<PageHeader
									title={title}
									description={description}
									lastUpdated={lastUpdatedText}
								/>
							)
						}

						<article
							data-pagefind-body
							class={cn(
								'prose-slate dark:prose-invert prose-headings:scroll-m-20 prose-headings:tracking-tight prose-a:font-medium prose-a:underline prose-a:underline-offset-4 prose-pre:border prose-pre:border-border/50',
								!isApi
									? 'prose max-w-none py-8'
									: 'flex w-full min-w-0 flex-1 flex-col text-foreground'
							)}
						>
							<slot />
						</article>

						{!isApi && <Pagination entry={entry} />}
					</div>

					{!isApi && <ToC headings={headings} />}
				</div>
			</main>
		</div>
	</body>
</html>
