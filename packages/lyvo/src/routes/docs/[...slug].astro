---
import { render } from 'astro:content';
import Accordion from '@lyvo/components/docs/Accordion.astro';
import DocsLayout from '@lyvo/layouts/DocsLayout.astro';
import { getCollection } from 'astro:content';
import Tabs from '@lyvo/components/docs/Tabs.astro';
import TabItem from '@lyvo/components/docs/TabItem.astro';
import CodeBlock from '@lyvo/components/base/CodeBlock.astro';
import Link from '@lyvo/components/base/Link.astro';
import Table from '@lyvo/components/docs/Table.astro';
import ImageWrapper from '@lyvo/components/base/ImageWrapper.astro';
import Callout from '@lyvo/components/docs/Callout.astro';
import Steps from '@lyvo/components/docs/Steps.astro';
import Step from '@lyvo/components/docs/Step.astro';
import FileTree from '@lyvo/components/docs/FileTree.astro';
import Folder from '@lyvo/components/docs/Folder.astro';
import File from '@lyvo/components/docs/File.astro';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	return docs.map((entry: any) => ({
		params: { slug: entry.id },
		props: { entry }
	}));
}

type Props = {
	entry: any;
};

const { entry } = Astro.props as Props;
const { Content, headings } = await render(entry);

const components = {
	Code: CodeBlock,
	a: Link,
	table: Table,
	img: ImageWrapper,
	Callout,
	Steps,
	Step,
	Tabs,
	TabItem,
	FileTree,
	Folder,
	File,
	Accordion
};

// Build TOC
const filteredHeadings = headings.filter((h: any) => h.depth === 2 || h.depth === 3);
---

<DocsLayout
	title={entry.data.title}
	description={entry.data.description}
	headings={filteredHeadings}
	entry={entry}
>
	<Content components={components} />
</DocsLayout>
