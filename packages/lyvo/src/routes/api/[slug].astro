---
import DocsLayout from '@lyvo/layouts/DocsLayout.astro';
import { marked } from 'marked';
import {
	getOpenAPIOperationBySlug,
	getOpenAPIWebhookBySlug,
	tryReadOpenAPIModel
} from '@lyvo/lib/openapi/model';
import type { OpenAPISnippet } from '@lyvo/lib/openapi/types';
import Tabs from '@lyvo/components/docs/Tabs.astro';
import TabItem from '@lyvo/components/docs/TabItem.astro';
import CodeBlock from '@lyvo/components/base/CodeBlock.astro';

// OpenAPI Extracted Components
import Parameters from '@lyvo/components/openapi/Parameters.astro';
import RequestBody from '@lyvo/components/openapi/RequestBody.astro';
import Responses from '@lyvo/components/openapi/Responses.astro';
import Authorization from '@lyvo/components/openapi/Authorization.astro';
import EndpointPath from '@lyvo/components/openapi/EndpointPath.astro';
import { ExternalLink } from '@lucide/astro';
import { staticRedirect } from '@lyvo/lib/utils';

const model = await tryReadOpenAPIModel();

export async function getStaticPaths() {
	const model = await tryReadOpenAPIModel();
	if (!model) return [];

	return [...model.operations, ...model.webhooks].map((endpoint) => ({
		params: { slug: endpoint.slug }
	}));
}

const { slug } = Astro.params;

if (!model) {
	return staticRedirect('/404');
}

const operation = getOpenAPIOperationBySlug(model, slug ?? '');
const webhook = operation ? null : getOpenAPIWebhookBySlug(model, slug ?? '');
const endpoint = operation ?? webhook;

if (!endpoint) {
	return staticRedirect('/404');
}

const isWebhook = webhook !== null;

function formatJson(value: unknown): string {
	if (value === undefined) return '';

	try {
		return JSON.stringify(value, null, 2);
	} catch {
		return String(value);
	}
}
---

<DocsLayout
	title={endpoint.title}
	description={endpoint.description ?? endpoint.summary}
	isApi={true}
>
	<div
		class="grid w-full grid-cols-1 lg:grid-cols-[1fr_400px] xl:grid-cols-[1fr_450px] 2xl:grid-cols-[1fr_550px]"
	>
		{/* LEFT SIDE (DOCS) */}
		<div class="min-w-0 px-4 py-8 sm:px-6 md:py-12 lg:px-8 xl:px-12">
			<div class="mx-auto max-w-4xl">
				<div class="mb-10 space-y-4">
					<h1 class="scroll-m-20 text-3xl font-bold tracking-tight md:text-4xl">
						{endpoint.title}
					</h1>
					{
						(endpoint.description ?? endpoint.summary) && (
							<div
								class="prose max-w-none prose-slate dark:prose-invert prose-headings:scroll-m-20 prose-p:text-base prose-p:text-muted-foreground md:prose-p:text-lg prose-a:text-primary prose-a:no-underline hover:prose-a:underline"
								set:html={marked.parse((endpoint.description ?? endpoint.summary) as string)}
							/>
						)
					}
					{
						endpoint.raw?.externalDocsUrl && (
							<div class="pt-2">
								<a
									href={endpoint.raw.externalDocsUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex items-center gap-1.5 text-sm font-medium text-blue-600 transition-colors hover:text-blue-700 hover:underline dark:text-blue-400 dark:hover:text-blue-300"
								>
									Read External Documentation
									<ExternalLink size={14} />
								</a>
							</div>
						)
					}
					{
						endpoint.tags.length > 0 && (
							<div class="flex flex-wrap gap-2">
								{endpoint.tags.map((tag) => (
									<span class="rounded-md border border-border bg-sidebar/50 px-2.5 py-1 text-xs font-medium text-muted-foreground">
										{tag}
									</span>
								))}
							</div>
						)
					}
				</div>

				<div class="space-y-12">
					<EndpointPath endpoint={endpoint} isWebhook={isWebhook} />
					<Parameters parameters={endpoint.parameters} />
					<Authorization security={endpoint.security} />
					<RequestBody requestBody={endpoint.requestBody} />
					<Responses responses={endpoint.responses} />
				</div>
			</div>
		</div>

		{/* RIGHT SIDE (CODE) */}
		<div class="border-t border-border bg-muted/10 lg:border-t-0 lg:border-l">
			<div class="no-scrollbar sticky top-14 h-auto overflow-y-auto p-4 sm:p-6 lg:p-8">
				<div class="flex flex-col gap-8">
					{
						endpoint.snippets.length > 0 && (
							<div>
								<h3 class="mb-4 text-sm font-semibold tracking-tight text-foreground/80">
									Code Samples
								</h3>
								<Tabs>
									{endpoint.snippets.map((snippet: OpenAPISnippet) => (
										<TabItem value={snippet.id} label={snippet.label}>
											<CodeBlock
												code={snippet.code}
												lang={snippet.language as any}
												wrap={true}
												class="font-mono text-sm"
											/>
										</TabItem>
									))}
								</Tabs>
							</div>
						)
					}

					{
						endpoint.responses.some((r) =>
							r.content.some((c) => c.example !== undefined)
						) && (
							<div>
								<h3 class="mb-4 text-sm font-semibold tracking-tight text-foreground/80">
									Example Responses
								</h3>
								<Tabs>
									{endpoint.responses.map((response) => {
										const jsonContent = response.content.find(
											(c) =>
												c.mediaType.includes('json') ||
												c.example !== undefined
										);
										if (!jsonContent || jsonContent.example === undefined)
											return null;

										return (
											<TabItem
												value={`res-${response.status}`}
												label={response.status}
											>
												<CodeBlock
													code={formatJson(jsonContent.example)}
													lang="json"
													wrap={true}
													class="font-mono text-sm"
												/>
											</TabItem>
										);
									})}
								</Tabs>
							</div>
						)
					}
				</div>
			</div>
		</div>
	</div>
</DocsLayout>
