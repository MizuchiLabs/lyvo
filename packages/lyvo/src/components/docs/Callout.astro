---
import { cn } from '../../lib/utils';
import { Info, TriangleAlert, CircleX, CircleCheck } from '@lucide/astro';

interface Props {
	type?: 'default' | 'warning' | 'danger' | 'success';
	title?: string;
}

const { type = 'default', title } = Astro.props;

const variants = {
	default: {
		Icon: Info,
		classes:
			'border-blue-200 bg-blue-50 text-blue-900 dark:border-blue-500/30 dark:bg-blue-500/10 dark:text-blue-200',
		iconClass: 'text-blue-600 dark:text-blue-400'
	},
	warning: {
		Icon: TriangleAlert,
		classes:
			'border-orange-200 bg-orange-50 text-orange-900 dark:border-orange-500/30 dark:bg-orange-500/10 dark:text-orange-200',
		iconClass: 'text-orange-600 dark:text-orange-400'
	},
	danger: {
		Icon: CircleX,
		classes:
			'border-red-200 bg-red-50 text-red-900 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-200',
		iconClass: 'text-red-600 dark:text-red-400'
	},
	success: {
		Icon: CircleCheck,
		classes:
			'border-green-200 bg-green-50 text-green-900 dark:border-green-500/30 dark:bg-green-500/10 dark:text-green-200',
		iconClass: 'text-green-600 dark:text-green-400'
	}
};

const { Icon, classes, iconClass } = variants[type];
---

<div class={cn('my-6 flex items-start rounded-xl border p-4 shadow-sm', classes)}>
	<Icon class={cn('mt-0.5 mr-3 h-5 w-5 shrink-0', iconClass)} />
	<div class="w-full min-w-0">
		{title && <h5 class="mb-1 leading-none font-semibold tracking-tight">{title}</h5>}
		<div
			class="text-sm leading-relaxed opacity-90 [&>*:first-child]:mt-0 [&>*:last-child]:mb-0"
		>
			<slot />
		</div>
	</div>
</div>
