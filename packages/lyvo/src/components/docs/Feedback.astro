---
import { ThumbsUp, ThumbsDown, Check } from '@lucide/astro';
import config from 'virtual:lyvo-config';
---

{
	config.docs.feedback && (
		<div class="feedback-widget">
			<div class="feedback-prompt flex flex-1 flex-col items-center gap-4 rounded-lg transition-all duration-300 sm:flex-row">
				<span class="text-sm font-medium text-muted-foreground">
					Was this page helpful?
				</span>
				<div class="flex items-center gap-2">
					<button
						data-helpful="true"
						class="feedback-btn flex items-center gap-2 rounded-full border border-border bg-background px-3 py-1.5 text-sm font-medium text-muted-foreground transition-all duration-200 hover:bg-accent hover:text-accent-foreground"
						aria-label="Yes, this page was helpful"
					>
						<ThumbsUp size={16} />
						Yes
					</button>
					<button
						data-helpful="false"
						class="feedback-btn flex items-center gap-2 rounded-full border border-border bg-background px-3 py-1.5 text-sm font-medium text-muted-foreground transition-all duration-200 hover:bg-accent hover:text-accent-foreground"
						aria-label="No, this page was not helpful"
					>
						<ThumbsDown size={16} />
						No
					</button>
				</div>
			</div>

			<div class="feedback-thanks hidden text-sm text-muted-foreground">
				<div class="flex items-center justify-center gap-2">
					<Check size={16} class="text-green-500" />
					<p>Thank you for your feedback!</p>
				</div>
			</div>
		</div>
	)
}

<style>
	@keyframes yes-pop {
		0% {
			transform: scale(1);
		}
		40% {
			transform: scale(1.25);
		}
		70% {
			transform: scale(0.95);
		}
		100% {
			transform: scale(1);
		}
	}

	@keyframes no-shake {
		0%,
		100% {
			transform: translateX(0);
		}
		20% {
			transform: translateX(-5px) rotate(-3deg);
		}
		40% {
			transform: translateX(5px) rotate(3deg);
		}
		60% {
			transform: translateX(-4px) rotate(-2deg);
		}
		80% {
			transform: translateX(4px) rotate(2deg);
		}
	}

	@keyframes thanks-in {
		0% {
			opacity: 0;
			transform: translateY(6px) scale(0.97);
		}
		100% {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	.feedback-btn-yes-active {
		animation: yes-pop 0.4s ease forwards;
		background-color: oklch(var(--color-green-500) / 0.15) !important;
		border-color: oklch(var(--color-green-500) / 0.5) !important;
		color: var(--color-green-600) !important;
	}

	.feedback-btn-no-active {
		animation: no-shake 0.45s ease forwards;
		background-color: oklch(var(--color-red-500) / 0.15) !important;
		border-color: oklch(var(--color-red-500) / 0.5) !important;
		color: var(--color-red-600) !important;
	}

	.feedback-thanks-visible {
		animation: thanks-in 0.35s ease forwards;
	}
</style>

<script>
	declare global {
		interface Window {
			umami?: { track: (event: string, data?: Record<string, any>) => void };
			plausible?: any;
			gtag?: any;
			fathom?: any;
			_paq?: any;
			posthog?: any;
		}
	}

	function sendFeedback(helpful: boolean, path: string) {
		const helpfulStr = helpful ? 'Yes' : 'No';

		if (window.umami?.track) {
			window.umami.track('feedback', { helpful: helpfulStr });
		}
		if (window.plausible) {
			window.plausible('Feedback', { props: { helpful: helpfulStr, path } });
		}
		if (window.gtag) {
			window.gtag('event', 'feedback', { helpful, path });
		}
		if (window.fathom?.trackEvent) {
			window.fathom.trackEvent(`feedback_${helpfulStr.toLowerCase()}`);
		}
		if (window._paq) {
			window._paq.push(['trackEvent', 'Feedback', helpfulStr, path]);
		}
		if (window.posthog?.capture) {
			window.posthog.capture('feedback', { helpful, path });
		}
	}

	function initFeedback() {
		document.querySelectorAll<HTMLDivElement>('.feedback-widget').forEach((widget) => {
			const prompt = widget.querySelector<HTMLElement>('.feedback-prompt')!;
			const thanks = widget.querySelector<HTMLElement>('.feedback-thanks')!;

			widget.querySelectorAll<HTMLButtonElement>('.feedback-btn').forEach((btn) => {
				// Prevent double-binding if View Transitions re-runs the script incorrectly
				if (btn.dataset.initialized) return;
				btn.dataset.initialized = 'true';

				btn.addEventListener('click', () => {
					const helpful = btn.dataset.helpful === 'true';

					try {
						sendFeedback(helpful, window.location.pathname);
					} catch (e) {
						console.error('Failed to send feedback event', e);
					}

					btn.classList.add(
						helpful ? 'feedback-btn-yes-active' : 'feedback-btn-no-active'
					);

					setTimeout(
						() => {
							prompt.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
							prompt.style.opacity = '0';
							prompt.style.transform = 'translateY(-4px)';

							setTimeout(() => {
								prompt.classList.add('hidden');
								thanks.classList.remove('hidden');
								thanks.classList.add('feedback-thanks-visible');
							}, 200);
						},
						helpful ? 350 : 420
					);
				});
			});
		});
	}

	document.addEventListener('astro:page-load', initFeedback);
</script>
