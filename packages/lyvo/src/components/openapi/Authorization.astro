---
import type { OpenAPISecurityRequirement } from '@lyvo/lib/openapi/types';

interface Props {
	security: OpenAPISecurityRequirement[];
}

const { security } = Astro.props;

if (!security || security.length === 0) return null;

function securityLabel(requirement: OpenAPISecurityRequirement): string {
	if (requirement.type === 'http') {
		return `${requirement.name} (${requirement.scheme ?? 'http'})`;
	}

	if (requirement.type === 'apiKey') {
		return `${requirement.name} (apiKey in ${requirement.in ?? 'unknown'})`;
	}

	return `${requirement.name} (${requirement.type})`;
}
---

<section>
	<h2 class="mb-4 text-xl font-semibold tracking-tight">Authorization</h2>
	<ul class="space-y-3">
		{
			security.map((item: OpenAPISecurityRequirement) => (
				<li class="rounded-xl border border-border bg-card p-4 shadow-sm">
					<p class="text-sm font-semibold">{securityLabel(item)}</p>
					{item.description && (
						<p class="mt-1 text-sm text-muted-foreground">{item.description}</p>
					)}
					{item.scopes.length > 0 && (
						<p class="mt-3 border-t border-border pt-3 text-xs text-muted-foreground">
							<span class="text-[10px] font-semibold tracking-wider uppercase">
								Scopes:
							</span>{' '}
							{item.scopes.join(', ')}
						</p>
					)}
				</li>
			))
		}
	</ul>
</section>
