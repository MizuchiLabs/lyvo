---
import { getProvider } from '@lyvo/lib/repo';
import config from 'virtual:lyvo-config';

interface Props {
	class?: string;
}

const { class: className } = Astro.props;
const type = getProvider(config.repo?.url, config.repo?.provider);

const svgs = import.meta.glob('@lyvo/assets/*.svg', {
	query: '?raw',
	import: 'default',
	eager: true
});

const svgKey =
	Object.keys(svgs).find((key) => key.endsWith(`/${type}.svg`)) ??
	Object.keys(svgs).find((key) => key.endsWith('/git.svg'));

const svgContent = svgs[svgKey!] as string;

const rendered = className
	? svgContent.replace(/<svg\s/, `<svg class="${className}" `)
	: svgContent;
---

<Fragment set:html={rendered} />
