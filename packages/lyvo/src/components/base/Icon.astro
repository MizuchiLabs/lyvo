---
interface Props {
	name: string;
	class?: string;
}

const { name, class: className } = Astro.props;

// Fetch all SVGs from the consumer's src/assets folder
const svgs = import.meta.glob('/src/assets/*.svg', {
	query: '?raw',
	import: 'default',
	eager: true
});

const svgKey = Object.keys(svgs).find(
	(key) => key.endsWith(`/${name}`) || key.endsWith(`/${name}.svg`)
);
const svgContent = svgKey ? (svgs[svgKey] as string) : null;

const rendered =
	svgContent && className
		? svgContent.replace(/<svg([^>]*)>/, `<svg class="${className}"$1>`)
		: svgContent;
---

{rendered ? <Fragment set:html={rendered} /> : <span>{name}</span>}
