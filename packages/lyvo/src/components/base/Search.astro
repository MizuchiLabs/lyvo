---
import PagefindConfig from 'astro-pagefind/components/PagefindConfig.astro';
---

<PagefindConfig />
<div class="mt-1">
	<pagefind-modal-trigger shortcut="/" placeholder="Search..."></pagefind-modal-trigger>
</div>

<script is:inline>
	// Fix: @pagefind/component-ui doesn't deregister components on disconnect.
	// After a View Transition, old dead elements stay registered in the Instance
	// and getUtilities("modal")[0] returns the old detached modal.
	// Clear component registrations before swap so new elements register fresh.
	if (!window.__pagefindVTFix) {
		window.__pagefindVTFix = true;
		document.addEventListener('astro:before-swap', () => {
			const el =
				document.querySelector('pagefind-config') ||
				document.querySelector('pagefind-modal') ||
				document.querySelector('pagefind-modal-trigger');
			if (el && el.instance) {
				el.instance.components = [];
				el.instance.componentsByType = {};
				el.instance.listeners = {};
				el.instance.activeShortcuts = [];
			}
		});
	}

	// Sync pagefind theme with dark mode (only set up observer once)
	if (!window.__pagefindThemeSync) {
		window.__pagefindThemeSync = true;
		const sync = () => {
			const dark = document.documentElement.classList.contains('dark');
			document.documentElement.setAttribute('data-pf-theme', dark ? 'dark' : 'light');
		};
		sync();
		new MutationObserver(sync).observe(document.documentElement, {
			attributes: true,
			attributeFilter: ['class']
		});
	} else {
		// Just sync current state on subsequent navigations
		const dark = document.documentElement.classList.contains('dark');
		document.documentElement.setAttribute('data-pf-theme', dark ? 'dark' : 'light');
	}
</script>

<div><pagefind-modal reset-on-close></pagefind-modal></div>

<style is:global>
	html[data-pf-theme='light'] {
		--pf-text: var(--foreground);
		--pf-text-secondary: var(--muted-foreground);
		--pf-text-muted: var(--muted-foreground);
		--pf-background: var(--background);
		--pf-border: var(--border);
		--pf-border-focus: var(--ring);
		--pf-hover: var(--accent);
		--pf-skeleton: var(--muted);
		--pf-skeleton-shine: var(--muted-foreground);
		--pf-mark: var(--foreground);
		--pf-scroll-shadow: rgba(0, 0, 0, 0.08);
		--pf-outline-focus: var(--ring);
		--pf-shadow-lg: var(--shadow-2xl);
		--pf-modal-max-width: 32rem;
		--pf-modal-max-height: min(70dvh, 600px);
		--pf-input-height: 32px;
		--pf-border-radius: var(--radius);
		--pf-font: var(--font-sans);
	}

	html[data-pf-theme='dark'] {
		--pf-text: var(--foreground);
		--pf-text-secondary: var(--muted-foreground);
		--pf-text-muted: var(--muted-foreground);
		--pf-background: var(--background);
		--pf-border: var(--border);
		--pf-border-focus: var(--ring);
		--pf-hover: var(--accent);
		--pf-skeleton: var(--muted);
		--pf-skeleton-shine: var(--muted-foreground);
		--pf-mark: var(--foreground);
		--pf-scroll-shadow: rgba(255, 255, 255, 0.1);
		--pf-outline-focus: var(--ring);
		--pf-shadow-lg: 0 16px 48px rgba(0, 0, 0, 0.5);
		--pf-shadow-lg: var(--shadow-2xl);
		--pf-modal-backdrop: rgba(0, 0, 0, 0.6);
		--pf-modal-max-width: 32rem;
		--pf-modal-max-height: min(70dvh, 600px);
		--pf-input-height: 32px;
		--pf-border-radius: var(--radius);
		--pf-font: var(--font-sans);
	}
</style>
