</svg>
`;

const renderedLogo = userLogo
	? userLogo.replace(/<svg([^>]*)>/, `<svg width="${size}" height="${size}"$1>`)
	: defaultLogo;
---

<a
	href="/"
	class="flex items-center gap-2 text-lg font-bold tracking-tight transition-opacity hover:opacity-80"
>
	<Fragment set:html={renderedLogo} />
	{titleText !== '' && <span>{titleText ?? 'Lyvo Docs'}</span>}
</a>
