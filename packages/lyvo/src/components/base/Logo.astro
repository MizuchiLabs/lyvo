---
import config from 'virtual:lyvo-config';

interface Props {
	size?: number;
}

const { size = 28 } = Astro.props;
const titleText = config.title;
const logoName = config.logo;

// Fetch all SVGs from the consumer's src/assets folder
const svgs = import.meta.glob('/src/assets/*.svg', {
	query: '?raw',
	import: 'default',
	eager: true
});

// If logo is provided in config, find it. Otherwise automatically look for 'logo.svg'
const svgKey = logoName
	? Object.keys(svgs).find(
			(key) => key.endsWith(`/${logoName}`) || key.endsWith(`/${logoName}.svg`)
		)
	: Object.keys(svgs).find((key) => key.endsWith(`/logo.svg`));

const userLogo = svgKey ? (svgs[svgKey] as string) : null;

// Lyvo logo
const defaultLogo = `
