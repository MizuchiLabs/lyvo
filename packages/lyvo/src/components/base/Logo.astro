	<defs>
		<linearGradient id="lyvo-color-1" gradientUnits="userSpaceOnUse" x1="50" y1="5" x2="50" y2="95">
			<stop style="stop-color: #a770ef;" offset="0" />
			<stop style="stop-color: #cf8bf3;" offset="0.5" />
			<stop style="stop-color: #fdb99b;" offset="1" />
		</linearGradient>
