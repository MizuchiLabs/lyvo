---
import ThemeToggle from '@/components/ThemeToggle.astro';
import RepoIcon from '@/components/RepoIcon.astro';
import BaseHead from '@/layouts/BaseHead.astro';
import Logo from '@/components/Logo.astro';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<BaseHead />

	<body
		class="flex min-h-screen flex-col bg-background font-sans text-foreground antialiased"
		transition:persist
		transition:name="page-layout"
	>
		<header
			class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-backdrop-filter:bg-background/60"
		>
			<div
				class="container mx-auto flex h-14 max-w-screen-2xl items-center justify-between px-4 md:px-8"
			>
				<div class="flex items-center gap-6">
					<Logo />
					<div class="hidden items-center gap-1 md:flex">
						<a
							href="/docs"
							class="rounded-md px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
						>
							Documentation
						</a>
						<a
							href="/api"
							class="rounded-md px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
						>
							OpenAPI
						</a>
					</div>
				</div>
				<div class="flex items-center space-x-2">
					<a
						href="https://github.com/mizuchilabs/lyvo"
						target="_blank"
						rel="noreferrer"
						class="rounded-full p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
						title="View on GitHub"
					>
						<span class="flex items-center justify-center [&>svg]:size-5 [&>svg]:dark:invert">
							<RepoIcon type="github" />
						</span>
						<span class="sr-only">GitHub</span>
					</a>
					<ThemeToggle />
				</div>
			</div>
		</header>
		<slot />
	</body>
</html>
