---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { ChevronRight, AlignLeft } from 'lucide-react';
import { getCollection } from 'astro:content';
import Search from '../components/Search';
import { SidebarNav, MobileSidebar } from '../components/Sidebar';

interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;

// Fetch all docs to generate the sidebar
const docs = await getCollection('docs');
docs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const categories = docs.reduce(
	(acc, doc) => {
		const cat = doc.data.category || 'General';
		if (!acc[cat]) {
			acc[cat] = [];
		}
		acc[cat].push(doc);
		return acc;
	},
	{} as Record<string, typeof docs>
);

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description || 'Documentation'} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} - Docs</title>
		<ClientRouter />
		<script is:inline>
			function applyTheme() {
				const theme = (() => {
					if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
						return localStorage.getItem('theme');
					}
					if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
						return 'dark';
					}
					return 'light';
				})();
				if (theme === 'dark') {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
				window.localStorage.setItem('theme', theme || 'light');
			}

			applyTheme();
			document.addEventListener('astro:after-swap', applyTheme);
		</script>
	</head>

	<body
		class="flex h-screen w-full flex-col overflow-hidden font-sans text-foreground antialiased md:flex-row"
	>
		{/* MOBILE HEADER */}
		<header
			class="flex h-14 shrink-0 items-center justify-between border-b border-border/40 bg-background px-4 md:hidden"
		>
			<MobileSidebar client:load categories={categories} currentPath={currentPath} />

			<div class="w-56">
				<Search client:load />
			</div>
		</header>

		{/* DESKTOP SIDEBAR  */}
		<aside class="hidden w-65 flex-col px-4 md:flex lg:w-70">
			{/* App Header / Logo */}
			<div class="flex h-16 shrink-0 items-center px-4">
				<a href="/" class="text-lg font-bold tracking-tight">Acme Docs</a>
			</div>
			<Search client:load />
			<SidebarNav client:load categories={categories} currentPath={currentPath} />
		</aside>

		{/* MAIN CONTENT WRAPPER */}
		{
			/* On mobile, it's just full width. On desktop, it gets padding and rounded corners to look like a floating app surface. */
		}
		<div class="flex h-full flex-1 flex-col overflow-hidden md:py-3 md:pr-3">
			{/* THE SCROLLABLE CONTENT BLOCK */}
			<main
				id="main-scroll-area"
				class="relative no-scrollbar flex-1 overflow-y-auto bg-muted/20 md:rounded-2xl md:border md:border-border/50 md:shadow-sm"
			>
				{/* Inner container to constrain text width so it's readable on ultra-wides */}
				<div
					class="mx-auto flex max-w-300 flex-col px-6 py-8 md:px-10 md:py-12 xl:flex-row xl:gap-12"
				>
					{/* Article Body */}
					<div class="mx-auto w-full min-w-0 flex-1">
						<div class="mb-4 flex items-center space-x-1 text-sm text-muted-foreground">
							<div class="overflow-hidden text-ellipsis whitespace-nowrap">Docs</div>
							<ChevronRight size={16} />
							<div class="font-medium text-foreground">{title}</div>
						</div>

						<div class="space-y-2">
							<h1 class="scroll-m-20 text-4xl font-bold tracking-tight">{title}</h1>
							{description && <p class="text-lg text-muted-foreground">{description}</p>}
						</div>

						<slot name="last-updated" />

						<div class="pt-8 pb-4">
							<article
								data-pagefind-body
								class="prose max-w-none prose-slate dark:prose-invert prose-headings:scroll-m-20 prose-headings:tracking-tight prose-a:font-medium prose-a:underline prose-a:underline-offset-4 prose-pre:border prose-pre:border-border/50"
							>
								<slot />
							</article>
						</div>

						{/* Next/Prev Navigation */}
						<slot name="footer" />
					</div>

					{/* TOC (Desktop) */}
					<div class="hidden w-60 shrink-0 text-sm xl:block">
						{/* Sticky inside the scrolling main container */}
						<div class="sticky top-12">
							<div class="space-y-4">
								<p class="flex items-center gap-2 font-medium text-foreground">
									<AlignLeft size={16} />
									On this page
								</p>
								<slot name="toc" />
							</div>
						</div>
					</div>
				</div>
			</main>
		</div>
	</body>
</html>
