---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { ChevronRight, AlignLeft } from 'lucide-react';
import { getCollection } from 'astro:content';
import Search from '@/components/Search';
import { SidebarNav, MobileSidebar } from '@/components/Sidebar';
import { SITE } from '@/config';

interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;

// Fetch all docs to generate the sidebar
const docs = await getCollection('docs');
docs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const categories = docs.reduce(
	(acc, doc) => {
		const cat = doc.data.category || 'General';
		if (!acc[cat]) {
			acc[cat] = [];
		}
		acc[cat].push(doc);
		return acc;
	},
	{} as Record<string, typeof docs>
);

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description || 'Documentation'} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} - {SITE.title}</title>
		<ClientRouter />
		<script is:inline>
			function applyTheme() {
				const theme = (() => {
					if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
						return localStorage.getItem('theme');
					}
					if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
						return 'dark';
					}
					return 'light';
				})();
				if (theme === 'dark') {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
				window.localStorage.setItem('theme', theme || 'light');
			}

			applyTheme();
			document.addEventListener('astro:after-swap', applyTheme);
		</script>
	</head>

	<body
		class="flex h-screen w-full flex-col overflow-hidden font-sans text-foreground antialiased md:flex-row"
	>
		{/* MOBILE HEADER */}
		<header
			class="flex h-14 shrink-0 items-center gap-2 border-b border-border/40 bg-background px-4 md:hidden"
		>
			<MobileSidebar client:load categories={categories} currentPath={currentPath} />
			<a href="/" class="flex items-center gap-2 text-lg font-bold tracking-tight">
				{
					(SITE.logo.type === 'logo' || SITE.logo.type === 'both') && (
						<img
							src={`/src/assets/${SITE.logo.src}`}
							alt={`${SITE.title} Logo`}
							width={SITE.logo.width}
							height={SITE.logo.height}
						/>
					)
				}
				{(SITE.logo.type === 'text' || SITE.logo.type === 'both') && <span>{SITE.title}</span>}
			</a>
			<div class="ml-auto w-40 sm:w-56">
				<Search client:load />
			</div>
		</header>

		{/* DESKTOP SIDEBAR  */}
		<aside class="hidden w-72 shrink-0 flex-col md:flex">
			{/* App Header / Logo */}
			<div class="flex h-14 shrink-0 items-center px-6">
				<a href="/" class="flex items-center gap-3 text-lg font-bold tracking-tight">
					{
						(SITE.logo.type === 'logo' || SITE.logo.type === 'both') && (
							<img
								src={`/src/assets/${SITE.logo.src}`}
								alt={`${SITE.title} Logo`}
								width={SITE.logo.width}
								height={SITE.logo.height}
							/>
						)
					}
					{(SITE.logo.type === 'text' || SITE.logo.type === 'both') && <span>{SITE.title}</span>}
				</a>
			</div>
			<div class="px-4 pt-2 pb-2">
				<Search client:load />
			</div>
			<div class="flex flex-1 flex-col overflow-hidden">
				<SidebarNav client:load categories={categories} currentPath={currentPath} />
			</div>
		</aside>

		{/* MAIN CONTENT WRAPPER */}
		{
			/* On mobile, it's just full width. On desktop, it gets padding and rounded corners to look like a floating app surface. */
		}
		<div class="flex h-full flex-1 flex-col overflow-hidden md:py-3 md:pr-3">
			{/* THE SCROLLABLE CONTENT BLOCK */}
			<main
				id="main-scroll-area"
				class="no-scrollbar relative flex-1 overflow-y-auto bg-muted/20 md:rounded-2xl md:shadow-sm"
			>
				{/* Sticky Breadcrumbs Header */}
				<div
					class="sticky top-0 z-30 flex items-center justify-between border-b border-border py-3 pr-4 pl-6 backdrop-blur-md"
				>
					<div class="flex items-center space-x-1 text-sm text-muted-foreground">
						<a
							href="/docs/introduction"
							class="overflow-hidden text-ellipsis whitespace-nowrap transition-colors hover:text-foreground"
							>Docs</a
						>
						<ChevronRight size={16} />
						<div class="font-medium text-foreground">{title}</div>
					</div>
					<slot name="header-actions" />
				</div>

				{/* Inner container to constrain text width so it's readable on ultra-wides */}
				<div class="mx-auto flex max-w-300 flex-col xl:flex-row xl:gap-12">
					{/* Article Body */}
					<div class="mx-auto w-full min-w-0 flex-1 px-6 py-8">
						<div class="space-y-2">
							<h1 class="scroll-m-20 text-4xl font-bold tracking-tight">{title}</h1>
							{description && <p class="text-lg text-muted-foreground">{description}</p>}
						</div>

						<slot name="last-updated" />

						<div class="pt-8 pb-4">
							<article
								data-pagefind-body
								class="prose max-w-none prose-slate dark:prose-invert prose-headings:scroll-m-20 prose-headings:tracking-tight prose-a:font-medium prose-a:underline prose-a:underline-offset-4 prose-pre:border prose-pre:border-border/50"
							>
								<slot />
							</article>
						</div>

						{/* Next/Prev Navigation */}
						<slot name="footer" />
					</div>

					{/* TOC (Desktop) */}
					<div class="hidden w-60 shrink-0 text-sm xl:block">
						{/* Sticky inside the scrolling main container */}
						<div class="no-scrollbar sticky top-20 max-h-[calc(100vh-8rem)] overflow-y-auto pb-8">
							<div class="space-y-4">
								<p class="flex items-center gap-2 font-medium text-foreground">
									<AlignLeft size={16} />
									On this page
								</p>
								<slot name="toc" />
							</div>
						</div>
					</div>
				</div>
			</main>
		</div>
	</body>
</html>
