---
import Search from '@/components/base/Search';
import Sidebar from '@/components/docs/Sidebar.astro';
import MobileToC from '@/components/docs/MobileToC.astro';
import ThemeToggle from '@/components/base/ThemeToggle.astro';
import BaseHead from '@/layouts/BaseHead.astro';
import ToC from '@/components/docs/ToC.astro';
import Breadcrumbs from '@/components/docs/Breadcrumbs.astro';
import PageHeader from '@/components/docs/PageHeader.astro';
import Pagination from '@/components/docs/Pagination.astro';
import fs from 'node:fs';

interface Props {
	title: string;
	description?: string;
	headings?: { depth: number; slug: string; text: string }[];
	entry?: any;
	showFeedback?: boolean;
	showEdit?: boolean;
}

const { title, description, headings = [], entry } = Astro.props;

let lastUpdated = () => {
	if (entry?.filePath) {
		const stats = fs.statSync(entry.filePath);
		return new Intl.DateTimeFormat(undefined, {
			month: 'short',
			day: 'numeric',
			year: 'numeric'
		}).format(stats.mtime);
	}
	return '';
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<BaseHead title={title} description={description} />

	<body
		class="flex h-screen w-full flex-col overflow-hidden bg-sidebar font-sans text-foreground antialiased md:flex-row"
		transition:persist
		transition:name="page-layout"
	>
		<Sidebar />

		{/* Main Content */}
		<div class="flex h-full flex-1 flex-col overflow-hidden rounded-xl md:py-3 md:pr-3">
			<main
				id="main-scroll-area"
				class="no-scrollbar relative flex-1 overflow-y-auto bg-background md:rounded-2xl md:border md:border-r-0 md:border-border/40 md:shadow-sm"
			>
				{/* Breadcrumbs Header */}
				<div
					class="sticky top-0 z-30 flex min-h-14 items-center justify-between gap-4 rounded-t-xl border-b border-border/40 bg-sidebar/50 px-6 backdrop-blur-md"
				>
					<Breadcrumbs title={title} />
					<MobileToC headings={headings} title={title} />
					<div class="flex shrink-0 items-center gap-4">
						<Search client:load />
						<ThemeToggle />
					</div>
				</div>

				{/* Inner container to constrain text width so it's readable on ultra-wides */}
				<div
					class="mx-auto flex max-w-5xl flex-col px-4 sm:px-6 md:px-8 xl:flex-row xl:gap-12"
				>
					{/* Article Body */}
					<div class="mx-auto w-full min-w-0 flex-1 py-8">
						<PageHeader
							title={title}
							description={description}
							lastUpdated={lastUpdated()}
						/>

						<article
							data-pagefind-body
							class="prose max-w-none py-8 prose-slate dark:prose-invert prose-headings:scroll-m-20 prose-headings:tracking-tight prose-a:font-medium prose-a:underline prose-a:underline-offset-4 prose-pre:border prose-pre:border-border/50"
						>
							<slot />
						</article>

						<Pagination entry={entry} />
					</div>

					<ToC headings={headings} />
				</div>
			</main>
		</div>
	</body>
</html>
