---
import { ChevronRight, ChevronLeft, TextAlignStart, Calendar } from '@lucide/astro';
import Search from '@/components/Search';
import Sidebar from '@/components/Sidebar.astro';
import MobileToc from '@/components/MobileToc';
import ThemeToggle from '@/components/ThemeToggle.astro';
import BaseHead from '@/layouts/BaseHead.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import Feedback from '@/components/Feedback.astro';
import EditPageLink from '@/components/EditPageLink.astro';
import { getPrevNextDocs } from '@/lib/docs';
import fs from 'node:fs';

interface Props {
	title: string;
	description?: string;
	headings?: { depth: number; slug: string; text: string }[];
	entry?: any;
}

const { title, description, headings = [], entry } = Astro.props;

// Editable configs for DocsLayout
const enableEdit = true;

let prevDoc, nextDoc;
if (entry) {
	const res = await getPrevNextDocs(entry.id);
	prevDoc = res.prevDoc;
	nextDoc = res.nextDoc;
}

let lastUpdated = '';
try {
	if (entry?.filePath) {
		const stats = fs.statSync(entry.filePath);
		lastUpdated = new Intl.DateTimeFormat(undefined, {
			month: 'short',
			day: 'numeric',
			year: 'numeric'
		}).format(stats.mtime);
	}
} catch (e) {
	// Ignore
}
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<BaseHead />

	<body
		class="flex h-screen w-full flex-col overflow-hidden bg-sidebar font-sans text-foreground antialiased md:flex-row"
		transition:persist
		transition:name="page-layout"
	>
		<Sidebar />

		{/* Main Content */}
		<div class="flex h-full flex-1 flex-col overflow-hidden md:py-3 md:pr-3">
			<main
				id="main-scroll-area"
				class="no-scrollbar relative flex-1 overflow-y-auto bg-background md:rounded-2xl md:border md:border-r-0 md:border-border/40 md:shadow-sm"
			>
				{/* Breadcrumbs Header */}
				<div
					class="sticky top-0 z-30 flex min-h-14 items-center justify-between gap-4 border-b border-border/40 bg-sidebar/50 px-6 backdrop-blur-md"
				>
					<div class="flex min-w-0 flex-1 items-center text-sm text-muted-foreground">
						<div class="hidden items-center space-x-1 xl:flex">
							<a
								href="/docs"
								class="overflow-hidden text-ellipsis whitespace-nowrap transition-colors hover:text-foreground"
							>
								Docs
							</a>
							<ChevronRight size={16} />
							<div class="font-medium text-foreground">{title}</div>
						</div>
						<div class="flex w-full xl:hidden">
							<MobileToc client:load headings={headings} title={title} />
						</div>
					</div>
					<div class="flex shrink-0 items-center gap-4">
						<div class="hidden w-64 md:block">
							<Search client:load />
						</div>
						<slot name="header-actions" />
						<ThemeToggle />
					</div>
				</div>

				{/* Inner container to constrain text width so it's readable on ultra-wides */}
				<div
					class="mx-auto flex max-w-5xl flex-col px-4 sm:px-6 md:px-8 xl:flex-row xl:gap-12"
				>
					{/* Article Body */}
					<div class="mx-auto w-full min-w-0 flex-1 py-8">
						<div class="space-y-2">
							<h1 class="scroll-m-20 text-4xl font-bold tracking-tight">{title}</h1>
							{
								description && (
									<p class="text-lg text-muted-foreground">{description}</p>
								)
							}
						</div>

						{
							lastUpdated && (
								<div class="mt-4 flex items-center gap-2 text-sm text-muted-foreground">
									<Calendar size={16} />
									Last updated on {lastUpdated}
								</div>
							)
						}

						<article
							data-pagefind-body
							class="prose max-w-none py-8 prose-slate dark:prose-invert prose-headings:scroll-m-20 prose-headings:tracking-tight prose-a:font-medium prose-a:underline prose-a:underline-offset-4 prose-pre:border prose-pre:border-border/50"
						>
							<slot />
						</article>

						{/* Next/Prev Navigation */}
						{
							entry && (
								<div class="mt-10 space-y-8">
									<div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
										<Feedback />
										{enableEdit && <EditPageLink filePath={entry.filePath} />}
									</div>

									<div class="grid grid-cols-1 gap-4 border-t border-border pt-8 sm:grid-cols-2">
										{prevDoc ? (
											<a
												href={`/docs/${prevDoc.id}`}
												class="group flex flex-col justify-center rounded-lg border border-border bg-card p-4 text-card-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
											>
												<div class="flex items-center gap-1 text-base font-semibold">
													<ChevronLeft
														class="transition-transform group-hover:-translate-x-1"
														size={16}
													/>
													{prevDoc.data.title}
												</div>
												{prevDoc.data.description && (
													<div class="mt-1 line-clamp-1 pl-3 text-sm text-muted-foreground">
														{prevDoc.data.description}
													</div>
												)}
											</a>
										) : (
											<div />
										)}

										{nextDoc ? (
											<a
												href={`/docs/${nextDoc.id}`}
												class="group ml-auto flex w-full flex-col justify-center rounded-lg border border-border bg-card p-4 text-right text-card-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
											>
												<div class="flex items-center justify-end gap-1 text-base font-semibold">
													{nextDoc.data.title}

													<ChevronRight
														class="transition-transform group-hover:translate-x-1"
														size={16}
													/>
												</div>
												{nextDoc.data.description && (
													<div class="mt-1 line-clamp-1 pr-3 text-sm text-muted-foreground">
														{nextDoc.data.description}
													</div>
												)}
											</a>
										) : (
											<div />
										)}
									</div>
								</div>
							)
						}
					</div>

					{/* TOC (Desktop) */}
					<div class="hidden w-64 shrink-0 text-sm xl:block">
						<div
							class="no-scrollbar sticky top-20 max-h-[calc(100vh-8rem)] overflow-y-auto pr-4 pb-8"
						>
							<div class="space-y-4">
								<p
									class="flex items-center gap-2 font-semibold tracking-tight text-foreground"
								>
									<TextAlignStart size={16} />
									On this page
								</p>
								<TableOfContents headings={headings} />
							</div>
						</div>
					</div>
				</div>
			</main>
		</div>
	</body>
</html>
