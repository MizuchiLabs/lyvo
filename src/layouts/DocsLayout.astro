---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { ChevronRight, AlignLeft } from 'lucide-react';
import { getCollection } from 'astro:content';
import Search from '@/components/Search';
import { SidebarNav, MobileSidebar } from '@/components/Sidebar';
import { SITE } from '@/config';
import { Image, Font } from 'astro:assets';

interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;

// Fetch all docs to generate the sidebar
const docs = await getCollection('docs');
docs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const categories = docs.reduce(
	(acc, doc) => {
		const parts = doc.id.split('/');
		let cat = 'root';
		if (parts.length > 1) {
			cat = parts[0];
			cat = cat
				.split('-')
				.map((word) => word.charAt(0).toUpperCase() + word.slice(1))
				.join(' ');
		}
		if (!acc[cat]) {
			acc[cat] = [];
		}
		acc[cat].push(doc);
		return acc;
	},
	{} as Record<string, typeof docs>
);

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description || 'Documentation'} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="Lyvo" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} - {SITE.title}</title>
		<Font cssVariable="--font-sans-default" preload />
		<Font cssVariable="--font-serif-default" preload />
		<Font cssVariable="--font-mono-default" preload />
		<ClientRouter />
		<script is:inline>
			function applyTheme() {
				const theme = (() => {
					if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
						return localStorage.getItem('theme');
					}
					if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
						return 'dark';
					}
					return 'light';
				})();
				if (theme === 'dark') {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
				window.localStorage.setItem('theme', theme || 'light');
			}

			applyTheme();
			document.addEventListener('astro:after-swap', applyTheme);
		</script>
	</head>

	<body
		class="flex h-screen w-full flex-col overflow-hidden bg-background font-sans text-foreground antialiased md:flex-row"
	>
		{/* SPACER FOR LARGE SCREENS to keep sidebar aligned with a 1536px container */}
		<div class="hidden shrink-0 md:block" style="width: max(0px, calc((100vw - 1536px) / 2));">
		</div>

		{/* MOBILE HEADER */}
		<header
			class="flex h-14 shrink-0 items-center gap-2 border-b border-border/40 bg-background px-4 md:hidden"
		>
			<MobileSidebar client:load categories={categories} currentPath={currentPath} />
			<a href="/" class="flex items-center gap-2 text-lg font-bold tracking-tight">
				{
					(SITE.logo.type === 'logo' || SITE.logo.type === 'both') && (
						<Image
							src={`/src/assets/${SITE.logo.src}`}
							alt={`${SITE.title} Logo`}
							width={SITE.logo.width}
							height={SITE.logo.height}
						/>
					)
				}
				{(SITE.logo.type === 'text' || SITE.logo.type === 'both') && <span>{SITE.title}</span>}
			</a>
			<div class="ml-auto w-40 sm:w-56">
				<Search client:load />
			</div>
		</header>

		{/* DESKTOP SIDEBAR  */}
		<aside class="hidden w-72 shrink-0 flex-col space-y-6 md:flex">
			<div class="flex shrink-0 items-center px-6 pt-6 pb-2">
				<a href="/" class="flex items-center gap-3 text-lg font-bold tracking-tight">
					{
						(SITE.logo.type === 'logo' || SITE.logo.type === 'both') && (
							<Image
								src={`/src/assets/${SITE.logo.src}`}
								alt={`${SITE.title} Logo`}
								width={SITE.logo.width}
								height={SITE.logo.height}
							/>
						)
					}
					{(SITE.logo.type === 'text' || SITE.logo.type === 'both') && <span>{SITE.title}</span>}
				</a>
			</div>
			<div class="flex flex-1 flex-col overflow-hidden">
				<SidebarNav client:load categories={categories} currentPath={currentPath} />
			</div>
		</aside>

		{/* Main Content */}
		<div class="flex h-full flex-1 flex-col overflow-hidden md:py-3 md:pr-3">
			<main
				id="main-scroll-area"
				class="no-scrollbar relative flex-1 overflow-y-auto bg-muted/30 md:rounded-2xl md:border md:border-r-0 md:border-border/40 md:shadow-sm"
			>
				{/* Breadcrumbs Header */}
				<div
					class="sticky top-0 z-30 flex min-h-14 items-center justify-between border-b border-border/40 bg-muted/40 px-6 backdrop-blur-md"
				>
					<div class="flex items-center space-x-1 text-sm text-muted-foreground">
						<a
							href="/docs/introduction"
							class="overflow-hidden text-ellipsis whitespace-nowrap transition-colors hover:text-foreground"
							>Docs</a
						>
						<ChevronRight size={16} />
						<div class="font-medium text-foreground">{title}</div>
					</div>
					<div class="flex items-center gap-4">
						<div class="hidden w-64 md:block">
							<Search client:load />
						</div>
						<slot name="header-actions" />
					</div>
				</div>

				{/* Inner container to constrain text width so it's readable on ultra-wides */}
				<div class="mx-auto flex max-w-6xl flex-col xl:flex-row xl:gap-12">
					{/* Article Body */}
					<div class="mx-auto w-full min-w-0 flex-1 py-8">
						<div class="flex items-center justify-between space-y-2">
							<div class="space-y-2">
								<h1 class="scroll-m-20 text-4xl font-bold tracking-tight">{title}</h1>
								{description && <p class="text-lg text-muted-foreground">{description}</p>}
							</div>
							<slot name="edit-button" />
						</div>

						<slot name="last-updated" />

						<article
							data-pagefind-body
							class="prose max-w-none py-8 prose-slate dark:prose-invert prose-headings:scroll-m-20 prose-headings:tracking-tight prose-a:font-medium prose-a:underline prose-a:underline-offset-4 prose-pre:border prose-pre:border-border/50"
						>
							<slot />
						</article>

						{/* Next/Prev Navigation */}
						<slot name="footer" />
					</div>

					{/* TOC (Desktop) */}
					<div class="hidden w-64 shrink-0 text-sm xl:block">
						<div
							class="no-scrollbar sticky top-20 max-h-[calc(100vh-8rem)] overflow-y-auto pr-4 pb-8"
						>
							<div class="space-y-4">
								<p class="flex items-center gap-2 font-semibold tracking-tight text-foreground">
									<AlignLeft size={16} />
									On this page
								</p>
								<slot name="toc" />
							</div>
						</div>
					</div>
				</div>
			</main>
		</div>
	</body>
</html>
