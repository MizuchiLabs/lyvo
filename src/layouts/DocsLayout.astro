---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { ChevronRight, AlignLeft } from 'lucide-react';
import { getCollection } from 'astro:content';
import Search from '@/components/Search';
import Sidebar from '@/components/Sidebar';
import { SITE } from '@/config';
import { Font } from 'astro:assets';
import ThemeToggle from '@/components/ThemeToggle.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;

// Fetch all docs to generate the sidebar
const docs = await getCollection('docs');
docs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const categories = docs.reduce(
	(acc, doc) => {
		const parts = doc.id.split('/');
		let cat = 'root';
		if (parts.length > 1) {
			cat = parts[0];
			cat = cat
				.split('-')
				.map((word) => word.charAt(0).toUpperCase() + word.slice(1))
				.join(' ');
		}
		if (!acc[cat]) {
			acc[cat] = [];
		}
		acc[cat].push(doc);
		return acc;
	},
	{} as Record<string, typeof docs>
);

const currentPath = Astro.url.pathname;

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/*.{jpeg,jpg,png,gif,svg}');
const logoSrcPath = `/src/assets/${SITE.logo.src}`;
const logoResolver = images[logoSrcPath];
const logoImage = logoResolver ? await logoResolver() : null;
const logoUrl = logoImage ? logoImage.default.src : undefined;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description || 'Documentation'} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} - {SITE.title}</title>
		<Font cssVariable="--font-sans-default" preload />
		<Font cssVariable="--font-serif-default" preload />
		<Font cssVariable="--font-mono-default" preload />
		<ClientRouter />
	</head>

	<body
		class="flex h-screen w-full flex-col overflow-hidden bg-sidebar font-sans text-foreground antialiased md:flex-row"
	>
		<Sidebar client:load categories={categories} currentPath={currentPath} logoUrl={logoUrl} />

		{/* Main Content */}
		<div class="flex h-full flex-1 flex-col overflow-hidden md:py-3 md:pr-3">
			<main
				id="main-scroll-area"
				class="no-scrollbar relative flex-1 overflow-y-auto bg-background md:rounded-2xl md:border md:border-r-0 md:border-border/40 md:shadow-sm"
			>
				{/* Breadcrumbs Header */}
				<div
					class="sticky top-0 z-30 flex min-h-14 items-center justify-between border-b border-border/40 bg-sidebar/50 px-6 backdrop-blur-md"
				>
					<div class="flex items-center space-x-1 text-sm text-muted-foreground">
						<a
							href="/docs/introduction"
							class="overflow-hidden text-ellipsis whitespace-nowrap transition-colors hover:text-foreground"
							>Docs</a
						>
						<ChevronRight size={16} />
						<div class="font-medium text-foreground">{title}</div>
					</div>
					<div class="flex items-center gap-4">
						<div class="hidden w-64 md:block">
							<Search client:load />
						</div>
						<slot name="header-actions" />
						<ThemeToggle />
					</div>
				</div>

				{/* Inner container to constrain text width so it's readable on ultra-wides */}
				<div class="mx-auto flex max-w-5xl flex-col px-4 sm:px-6 md:px-8 xl:flex-row xl:gap-12">
					{/* Article Body */}
					<div class="mx-auto w-full min-w-0 flex-1 py-8">
						<div class="flex items-center justify-between space-y-2">
							<div class="space-y-2">
								<h1 class="scroll-m-20 text-4xl font-bold tracking-tight">{title}</h1>
								{description && <p class="text-lg text-muted-foreground">{description}</p>}
							</div>
							<slot name="edit-button" />
						</div>

						<slot name="last-updated" />

						<article
							data-pagefind-body
							class="prose max-w-none py-8 prose-slate dark:prose-invert prose-headings:scroll-m-20 prose-headings:tracking-tight prose-a:font-medium prose-a:underline prose-a:underline-offset-4 prose-pre:border prose-pre:border-border/50"
						>
							<slot />
						</article>

						{/* Next/Prev Navigation */}
						<slot name="footer" />
					</div>

					{/* TOC (Desktop) */}
					<div class="hidden w-64 shrink-0 text-sm xl:block">
						<div
							class="no-scrollbar sticky top-20 max-h-[calc(100vh-8rem)] overflow-y-auto pr-4 pb-8"
						>
							<div class="space-y-4">
								<p class="flex items-center gap-2 font-semibold tracking-tight text-foreground">
									<AlignLeft size={16} />
									On this page
								</p>
								<slot name="toc" />
							</div>
						</div>
					</div>
				</div>
			</main>
		</div>
	</body>
</html>

<script is:inline>
	function applyTheme() {
		const theme = (() => {
			if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
				return localStorage.getItem('theme');
			}
			if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
				return 'dark';
			}
			return 'light';
		})();
		if (theme === 'dark') {
			document.documentElement.classList.add('dark');
		} else {
			document.documentElement.classList.remove('dark');
		}
		window.localStorage.setItem('theme', theme || 'light');
	}

	applyTheme();
	document.addEventListener('astro:after-swap', applyTheme);
</script>
