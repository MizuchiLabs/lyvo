---
import { ChevronRight } from '@lucide/astro';
import Search from '@/components/Search';
import Sidebar from '@/components/Sidebar.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
import BaseHead from '@/layouts/BaseHead.astro';

interface Props {
	title: string;
	description?: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<BaseHead />

	<body
		class="flex h-screen w-full flex-col overflow-hidden bg-sidebar font-sans text-foreground antialiased md:flex-row"
		transition:persist
		transition:name="page-layout"
	>
		<Sidebar />

		<div class="flex h-full flex-1 flex-col overflow-hidden md:py-3 md:pr-3">
			<main
				id="main-scroll-area"
				class="no-scrollbar relative flex-1 overflow-y-auto bg-background md:rounded-2xl md:border md:border-r-0 md:border-border/40 md:shadow-sm"
			>
				<div
					class="sticky top-0 z-30 flex min-h-14 items-center justify-between gap-4 border-b border-border/40 bg-sidebar/50 px-6 backdrop-blur-md"
				>
					<div class="flex min-w-0 flex-1 items-center text-sm text-muted-foreground">
						<div class="hidden items-center space-x-1 xl:flex">
							<a
								href="/api"
								class="overflow-hidden text-ellipsis whitespace-nowrap transition-colors hover:text-foreground"
							>
								API
							</a>
							<ChevronRight size={16} />
							<div class="font-medium text-foreground">{title}</div>
						</div>
						<div class="font-medium text-foreground xl:hidden">{title}</div>
					</div>
					<div class="flex shrink-0 items-center gap-4">
						<div class="hidden w-64 md:block">
							<Search client:load />
						</div>
						<slot name="header-actions" />
						<ThemeToggle />
					</div>
				</div>

				<article
					data-pagefind-body
					class="flex w-full min-w-0 flex-1 flex-col text-foreground"
				>
					<slot />
				</article>
			</main>
		</div>
	</body>
</html>
