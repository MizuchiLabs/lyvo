---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
	url?: string;
}

const { url } = Astro.props;

let changelog = '';

try {
	if (url && (url.startsWith('http://') || url.startsWith('https://'))) {
		const res = await fetch(url);
		if (!res.ok) throw new Error(`Failed to fetch: ${res.statusText}`);
		changelog = await res.text();
	} else {
		const changelogPath = path.resolve(process.cwd(), url || 'CHANGELOG.md');
		changelog = fs.readFileSync(changelogPath, 'utf-8');
	}
} catch (e) {
	console.error('Error loading changelog:', e);
}

const versionRegex = /##\s+\[(.*?)\](?:\s*-\s*(.*))?\n([\s\S]*?)(?=\n##\s+\[|$)/g;

const releases = [];
let match;
while ((match = versionRegex.exec(changelog)) !== null) {
	const version = match[1];

	// Format date nicely
	let date = '';
	if (match[2]) {
		try {
			date = new Date(match[2]).toLocaleDateString('en-US', {
				year: 'numeric',
				month: 'long',
				day: 'numeric'
			});
		} catch (e) {
			date = match[2];
		}
	}

	const content = match[3];
	const categories = [];
	const catRegex = /###\s+(.*)\n([\s\S]*?)(?=\n###\s+|$)/g;

	let catMatch;
	while ((catMatch = catRegex.exec(content)) !== null) {
		const type = catMatch[1].trim();
		const items = catMatch[2]
			.split('\n')
			.filter((line) => line.trim().startsWith('-'))
			.map((line) => line.replace(/^- /, '').trim());

		categories.push({ type, items });
	}

	releases.push({ version, date, categories });
}

const categoryColors: Record<string, string> = {
	Added: 'bg-green-500/10 text-green-600 dark:text-green-400 border-green-500/20',
	Fixed: 'bg-red-500/10 text-red-600 dark:text-red-400 border-red-500/20',
	Changed: 'bg-blue-500/10 text-blue-600 dark:text-blue-400 border-blue-500/20',
	Deprecated: 'bg-orange-500/10 text-orange-600 dark:text-orange-400 border-orange-500/20',
	Removed: 'bg-red-500/10 text-red-600 dark:text-red-400 border-red-500/20',
	Security: 'bg-purple-500/10 text-purple-600 dark:text-purple-400 border-purple-500/20'
};

// Very basic inline markdown code backtick parser
function parseInlineCode(text: string) {
	return text.replace(
		/`([^`]+)`/g,
		'<code class="relative rounded bg-muted px-[0.3rem] py-[0.2rem] font-mono text-sm font-medium text-foreground">$1</code>'
	);
}
---

<div class="not-prose relative mt-8 ml-3 space-y-12 border-l border-border/60 pb-8 md:ml-4">
	{
		releases.map((release) => (
			<div class="relative pl-8 md:pl-12">
				{/* Timeline Dot */}
				<div class="absolute top-1.5 -left-[9px] h-4 w-4 rounded-full border-2 border-background bg-primary shadow-sm ring-2 ring-border/60" />

				{/* Release Header */}
				<div class="mb-6 flex flex-col gap-2 sm:flex-row sm:items-baseline">
					<h2 class="m-0 text-2xl font-bold tracking-tight text-foreground">v{release.version}</h2>
					{release.date && (
						<span class="text-sm font-medium text-muted-foreground">{release.date}</span>
					)}
				</div>

				{/* Categories */}
				<div class="space-y-6">
					{release.categories.map((cat) => {
						const colorClass =
							categoryColors[cat.type] || 'bg-muted text-muted-foreground border-border';
						return (
							<div class="space-y-3">
								<div
									class={`inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold shadow-sm ${colorClass}`}
								>
									{cat.type}
								</div>
								<ul class="list-disc space-y-2 pl-5 text-muted-foreground marker:text-muted-foreground/50">
									{cat.items.map((item) => (
										<li class="leading-relaxed" set:html={parseInlineCode(item)} />
									))}
								</ul>
							</div>
						);
					})}
				</div>
			</div>
		))
	}

	{
		releases.length === 0 && (
			<div class="pl-8 text-muted-foreground">No releases found in CHANGELOG.md</div>
		)
	}
</div>
