---
import { Globe } from '@lucide/astro';

interface Props {
	platform: string;
	class?: string;
	[key: string]: any;
}

const { platform, class: className, ...props } = Astro.props;

const svgs = import.meta.glob('/src/assets/*.svg', {
	query: '?raw',
	import: 'default',
	eager: true
});

const aliases: Record<string, string> = { twitter: 'x' };
const name = aliases[platform.toLowerCase()] ?? platform.toLowerCase();
const svgContent = svgs[`/src/assets/${name}.svg`] as string | undefined;

const rendered =
	svgContent && className
		? svgContent.replace(/<svg\s/, `<svg class="${className}" `)
		: svgContent;
---

{rendered ? <Fragment set:html={rendered} /> : <Globe class={className} {...props} />}
