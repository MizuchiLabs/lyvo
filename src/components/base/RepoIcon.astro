---
import { getProvider } from '@/lib/repo';
import config from 'virtual:lyvo-config';

interface Props {
	class?: string;
}

const { class: className } = Astro.props;
const type = getProvider(config.repo?.url, config.repo?.provider);

const svgs = import.meta.glob('/src/assets/*.svg', {
	query: '?raw',
	import: 'default',
	eager: true
});

const svgContent = (svgs[`/src/assets/${type}.svg`] ?? svgs['/src/assets/git.svg']) as string;

const rendered = className
	? svgContent.replace(/<svg\s/, `<svg class="${className}" `)
	: svgContent;
---

<Fragment set:html={rendered} />
