---
import { getProviderFromUrl } from '@/lib/repo';

interface Props {
	url?: string;
	class?: string;
}

const { url, class: className } = Astro.props;
const type = getProviderFromUrl(url);

const svgs = import.meta.glob('/src/assets/*.svg', {
	query: '?raw',
	import: 'default',
	eager: true
});

const svgContent = (svgs[`/src/assets/${type}.svg`] ?? svgs['/src/assets/git.svg']) as string;

const rendered = className
	? svgContent.replace(/<svg\s/, `<svg class="${className}" `)
	: svgContent;
---

<Fragment set:html={rendered} />
