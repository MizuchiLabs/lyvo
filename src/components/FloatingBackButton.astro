---
import { House, Book } from '@lucide/astro';
import { SITE } from '@/config';
---

<div class="nav-floating-pill">
	<a href="/" class="nav-pill-item" title="Home">
		<House size={16} />
	</a>
	<div class="nav-divider"></div>
	<a
		href={SITE.nav.find((item) => item.title.toLowerCase().includes('doc'))?.href}
		class="nav-pill-item"
		title="Back to Docs"
	>
		<Book size={16} />
	</a>
</div>

<style>
	.nav-floating-pill {
		position: fixed;
		bottom: 1rem;
		right: 1rem;
		z-index: 99999;
		display: flex;
		gap: 8px;
		padding: 8px 10px;
		align-items: center;
		border-radius: 999px;

		/* Glassmorphism effects */
		background-color: rgba(24, 24, 27, 0.85);
		border-color: rgba(255, 255, 255, 0.1);
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
		-webkit-backdrop-filter: blur(12px);
		backdrop-filter: blur(12px);
		border: 1px solid rgba(0, 0, 0, 0.08);
	}

	.nav-floating-pill:hover {
		box-shadow:
			0 6px 20px rgba(0, 0, 0, 0.08),
			0 2px 6px rgba(0, 0, 0, 0.04);
	}

	.nav-pill-item {
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		color: #a1a1aa;
		text-decoration: none;
		transition: all 0.2s ease;
	}

	.nav-pill-item:hover {
		background-color: rgba(255, 255, 255, 0.1);
		color: #fafafa;
	}

	.nav-divider {
		width: 1px;
		height: 20px;
		background-color: rgba(255, 255, 255, 0.1);
		margin: 0 0.15rem;
	}
</style>
