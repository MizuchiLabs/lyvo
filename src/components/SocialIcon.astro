---
import { Globe } from '@lucide/astro';

interface Props {
	platform: string;
	class?: string;
	className?: string;
	[key: string]: any;
}

const { platform, class: astroClass, className: reactClass, ...props } = Astro.props;
const finalClass = astroClass || reactClass || '';

// We use import.meta.glob to dynamically read the raw SVGs
const svgs = import.meta.glob('/src/assets/*.svg', {
	query: '?raw',
	import: 'default',
	eager: true
});

let svgName = platform.toLowerCase();
if (svgName === 'twitter') svgName = 'x';
if (svgName === 'linkedin') svgName = 'bluesky';

const svgContent = svgs[`/src/assets/${svgName}.svg`] as string | undefined;

let renderedSvg = svgContent;
if (renderedSvg && finalClass) {
	// Inject the class attribute into the root <svg> tag
	renderedSvg = renderedSvg.replace(/<svg\s/, `<svg class="${finalClass}" `);
}
---

{renderedSvg ? <Fragment set:html={renderedSvg} /> : <Globe class={finalClass} {...props} />}
