---
import { SITE } from '@/config';
import { cn } from '@/lib/utils';
import { ChevronRight, ExternalLink } from '@lucide/astro';
import RepoIcon from './RepoIcon.astro';
import SocialIcon from './SocialIcon.astro';

interface Props {
	categories: Record<string, any[]>;
	currentPath: string;
	version?: string;
}

const { categories, currentPath, version } = Astro.props;

const topLevelItems = [
	...(categories['root'] || []).map((doc) => ({
		type: 'link' as const,
		id: doc.id.split('/')[0],
		title: doc.data.title,
		doc
	})),
	...Object.entries(categories)
		.filter(([category]) => category !== 'root')
		.map(([category, items]) => ({
			type: 'category' as const,
			id: category.toLowerCase().replace(/ /g, '-'),
			title: category,
			items
		}))
];

topLevelItems.sort((a, b) => {
	const orderA = SITE.categoryOrder?.indexOf(a.id) ?? -1;
	const orderB = SITE.categoryOrder?.indexOf(b.id) ?? -1;
	if (orderA !== -1 && orderB !== -1) return orderA - orderB;
	if (orderA !== -1) return -1;
	if (orderB !== -1) return 1;
	return a.title.localeCompare(b.title);
});
---

<div class="no-scrollbar flex-1 overflow-y-auto px-4">
	<div class="flex flex-col gap-1 pt-4 pb-2 md:pt-0">
		{
			topLevelItems.map((item) => {
				if (item.type === 'link') {
					const href = `/docs/${item.doc.id}`;
					const isActive = currentPath === href || currentPath === href + '/';
					return (
						<a
							href={href}
							class={cn(
								'group flex w-full items-center rounded-md border border-transparent px-2 py-1.5 text-sm font-semibold transition-colors select-none',
								isActive
									? 'text-foreground'
									: 'text-muted-foreground hover:bg-muted/50 hover:text-foreground'
							)}
						>
							{item.title}
						</a>
					);
				}

				const isCategoryActive = item.items.some((doc) => {
					const href = `/http://localhost:4321/docs/introductiondocs/${doc.id}`;
					return currentPath === href || currentPath === href + '/';
				});

				return (
					<div class="pb-1">
						<details class="group" open>
							<summary
								class={cn(
									'flex cursor-pointer list-none items-center justify-between rounded-md px-2 py-1.5 text-sm font-semibold transition-colors select-none [&::-webkit-details-marker]:hidden',
									isCategoryActive
										? 'text-foreground'
										: 'text-muted-foreground hover:bg-muted/50 hover:text-foreground'
								)}
							>
								{item.title}
								<ChevronRight
									class="opacity-50 transition-transform group-open:rotate-90"
									size={16}
								/>
							</summary>
							<div class="mt-1 ml-4 flex flex-col gap-1 border-l border-border/70 pl-2 text-sm">
								{item.items.map((doc) => {
									const href = `/docs/${doc.id}`;
									const isActive = currentPath === href || currentPath === href + '/';
									return (
										<a
											href={href}
											class={cn(
												'group flex w-full items-center rounded-md border border-transparent px-2 py-1.5 text-sm transition-colors select-none',
												isActive
													? 'bg-accent/50 font-medium text-foreground'
													: 'text-muted-foreground hover:bg-muted/50 hover:text-foreground'
											)}
										>
											{doc.data.title}
										</a>
									);
								})}
							</div>
						</details>
					</div>
				);
			})
		}
	</div>
</div>

<div class="mt-auto p-4">
	{
		SITE.extraLinks && SITE.extraLinks.length > 0 && (
			<div class="mb-4 flex flex-col gap-1">
				{SITE.extraLinks.map((link) => (
					<a
						href={link.href}
						target="_blank"
						rel="noreferrer"
						class="flex items-center justify-between rounded-md p-2 text-xs text-muted-foreground transition-colors hover:bg-muted/50 hover:text-foreground"
					>
						{link.title}
						<ExternalLink size={12} class="opacity-50" />
					</a>
				))}
			</div>
		)
	}

	<div class="h-px w-full bg-border/40"></div>
	<div class="mt-4 flex items-center justify-between">
		<div class="flex items-center gap-1">
			{
				SITE.repo.url && (
					<a
						href={SITE.repo.url}
						target="_blank"
						rel="noreferrer"
						class="rounded-md p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
						title={`View on ${SITE.repo.type}`}
					>
						<RepoIcon className="size-5 dark:invert" />
						<span class="sr-only">{SITE.repo.type}</span>
					</a>
				)
			}

			{
				Object.entries(SITE.social).map(([platform, url]) => {
					if (!url) return null;
					return (
						<a
							href={url}
							target="_blank"
							rel="noreferrer"
							class="rounded-md p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
							title={platform.charAt(0).toUpperCase() + platform.slice(1)}
						>
							<SocialIcon platform={platform} className="size-5 dark:invert" />
							<span class="sr-only">{platform}</span>
						</a>
					);
				})
			}
		</div>

		{
			version && (
				<div class="rounded-md bg-muted/50 px-2 py-1 text-[10px] font-medium tracking-tight text-muted-foreground">
					{version}
				</div>
			)
		}
	</div>
</div>
