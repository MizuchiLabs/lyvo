---
import { cn } from '@/lib/utils';
import { ChevronRight, ExternalLink, Webhook } from '@lucide/astro';
import RepoIcon from './RepoIcon.astro';
import SocialIcon from './SocialIcon.astro';
import type { OpenAPINavigationGroup } from '@/lib/openapi/types';

interface Props {
	topLevelItems: any[];
	currentPath: string;
	version?: string;
	apiGroups?: OpenAPINavigationGroup[];
	hasApiMode?: boolean;
	activeMode?: 'docs' | 'api';
}

const {
	topLevelItems,
	currentPath,
	version,
	apiGroups = [],
	hasApiMode = false,
	activeMode = 'docs'
} = Astro.props;

// Editable configs for SidebarNav
const extraLinks = [
	{ title: 'Support', href: 'https://example.com/support' },
	{ title: 'Status', href: 'https://status.example.com' }
];
const repoUrl = 'https://github.com/mizuchilabs/lyvo';
const repoType = 'github';
const socialLinks = { discord: '', x: '', youtube: '', bluesky: '' };
const methodClassMap = {
	get: 'text-emerald-600 dark:text-emerald-400',
	post: 'text-blue-600 dark:text-blue-400',
	put: 'text-amber-600 dark:text-amber-400',
	patch: 'text-yellow-600 dark:text-yellow-300',
	delete: 'text-rose-600 dark:text-rose-400',
	head: 'text-violet-600 dark:text-violet-300',
	options: 'text-cyan-600 dark:text-cyan-400',
	trace: 'text-fuchsia-600 dark:text-fuchsia-400'
} as const;
---

<div class="no-scrollbar flex-1 overflow-y-auto px-4">
	{
		hasApiMode && (
			<div class="mb-3 mt-2 grid grid-cols-2 gap-1 rounded-lg border border-border/70 bg-muted/30 p-1">
				<a
					href="/docs"
					class={cn(
						'rounded-md px-2 py-1.5 text-center text-xs font-semibold transition-colors',
						activeMode === 'docs'
							? 'bg-background text-foreground shadow-sm'
							: 'text-muted-foreground hover:text-foreground'
					)}
				>
					Docs
				</a>
				<a
					href="/api"
					class={cn(
						'rounded-md px-2 py-1.5 text-center text-xs font-semibold transition-colors',
						activeMode === 'api'
							? 'bg-background text-foreground shadow-sm'
							: 'text-muted-foreground hover:text-foreground'
					)}
				>
					API
				</a>
			</div>
		)
	}

	<div class="flex flex-col gap-1 pt-4 pb-2 md:pt-0">
		{
			(activeMode === 'api' ? apiGroups : topLevelItems).map((item) => {
				if (activeMode === 'api') {
					const isGroupActive = item.items.some((endpoint: any) => {
						const href = `/api/${endpoint.slug}`;
						return currentPath === href || currentPath === href + '/';
					});

					return (
						<div class="pb-1">
							<details class="group" open={isGroupActive}>
								<summary
									class={cn(
										'flex cursor-pointer list-none items-center justify-between rounded-md px-2 py-1.5 text-sm font-semibold transition-colors select-none [&::-webkit-details-marker]:hidden',
										isGroupActive
											? 'text-foreground'
											: 'text-muted-foreground hover:bg-muted/50 hover:text-foreground'
									)}
								>
									{item.title}
									<ChevronRight
										class="opacity-50 transition-transform group-open:rotate-90"
										size={16}
									/>
								</summary>
								<div class="mt-1 ml-4 flex flex-col gap-1 border-l border-border/70 pl-2 text-sm">
									{item.items.map((endpoint: any) => {
										const href = `/api/${endpoint.slug}`;
										const isActive =
											currentPath === href || currentPath === href + '/';

										return (
											<a
												href={href}
												class={cn(
													'group flex items-start gap-2 rounded-md border border-transparent px-2 py-1.5 text-sm transition-colors select-none',
													isActive
														? 'bg-accent/50 font-medium text-foreground'
														: 'text-muted-foreground hover:bg-muted/50 hover:text-foreground'
												)}
											>
												<span
													class={cn(
														'mt-0.5 rounded border border-current/30 px-1 py-0 text-[10px] font-semibold uppercase leading-4',
														methodClassMap[
															endpoint.method as keyof typeof methodClassMap
														]
													)}
												>
													{endpoint.method}
												</span>
												<span class="line-clamp-2 leading-5">{endpoint.label}</span>
												{endpoint.isWebhook && (
													<span class="ms-auto inline-flex items-center gap-1 rounded-full border border-fuchsia-500/30 bg-fuchsia-500/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase text-fuchsia-600 dark:text-fuchsia-300">
														<Webhook size={10} />
														Hook
													</span>
												)}
											</a>
										);
									})}
								</div>
							</details>
						</div>
					);
				}

				if (item.type === 'doc') {
					const href = `/docs/${item.doc.id}`;
					const isActive = currentPath === href || currentPath === href + '/';
					return (
						<a
							href={href}
							class={cn(
								'group flex w-full items-center rounded-md border border-transparent px-2 py-1.5 text-sm font-semibold transition-colors select-none',
								isActive
									? 'text-foreground'
									: 'text-muted-foreground hover:bg-muted/50 hover:text-foreground'
							)}
						>
							{item.title}
						</a>
					);
				}

				const isCategoryActive = item.items.some((doc: any) => {
					const href = `/docs/${doc.id}`;
					return currentPath === href || currentPath === href + '/';
				});

				return (
					<div class="pb-1">
						<details class="group" open>
							<summary
								class={cn(
									'flex cursor-pointer list-none items-center justify-between rounded-md px-2 py-1.5 text-sm font-semibold transition-colors select-none [&::-webkit-details-marker]:hidden',
									isCategoryActive
										? 'text-foreground'
										: 'text-muted-foreground hover:bg-muted/50 hover:text-foreground'
								)}
							>
								{item.title}
								<ChevronRight
									class="opacity-50 transition-transform group-open:rotate-90"
									size={16}
								/>
							</summary>
							<div class="mt-1 ml-4 flex flex-col gap-1 border-l border-border/70 pl-2 text-sm">
								{item.items.map((doc: any) => {
									const href = `/docs/${doc.id}`;
									const isActive =
										currentPath === href || currentPath === href + '/';
									return (
										<a
											href={href}
											class={cn(
												'group flex w-full items-center rounded-md border border-transparent px-2 py-1.5 text-sm transition-colors select-none',
												isActive
													? 'bg-accent/50 font-medium text-foreground'
													: 'text-muted-foreground hover:bg-muted/50 hover:text-foreground'
											)}
										>
											{doc.data.title}
										</a>
									);
								})}
							</div>
						</details>
					</div>
				);
			})
		}
	</div>
</div>

<div class="mt-auto p-4">
	{
		extraLinks && extraLinks.length > 0 && (
			<div class="mb-4 flex flex-col gap-1">
				{extraLinks.map((link) => (
					<a
						href={link.href}
						target="_blank"
						rel="noreferrer"
						class="flex items-center justify-between rounded-md p-2 text-xs text-muted-foreground transition-colors hover:bg-muted/50 hover:text-foreground"
					>
						{link.title}
						<ExternalLink size={12} class="opacity-50" />
					</a>
				))}
			</div>
		)
	}

	<div class="h-px w-full bg-border/40"></div>
	<div class="mt-4 flex items-center justify-between">
		<div class="flex items-center gap-1">
			{
				repoUrl && (
					<a
						href={repoUrl}
						target="_blank"
						rel="noreferrer"
						class="rounded-md p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
						title={`View on ${repoType}`}
					>
						<RepoIcon type={repoType} class="size-5 dark:invert" />
						<span class="sr-only">{repoType}</span>
					</a>
				)
			}

			{
				Object.entries(socialLinks).map(([platform, url]) => {
					if (!url) return null;
					return (
						<a
							href={url}
							target="_blank"
							rel="noreferrer"
							class="rounded-md p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
							title={platform.charAt(0).toUpperCase() + platform.slice(1)}
						>
							<SocialIcon platform={platform} className="size-5 dark:invert" />
							<span class="sr-only">{platform}</span>
						</a>
					);
				})
			}
		</div>

		{
			version && (
				<div class="rounded-md bg-muted/50 px-2 py-1 text-[10px] font-medium tracking-tight text-muted-foreground">
					{version}
				</div>
			)
		}
	</div>
</div>
