---
interface Props {
	type?: 'git' | 'gitea' | 'github' | 'gitlab' | 'forgejo';
	class?: string;
}

const { type = 'github', class: className } = Astro.props;

const svgs = import.meta.glob('/src/assets/*.svg', {
	query: '?raw',
	import: 'default',
	eager: true
});

const svgContent = (svgs[`/src/assets/${type}.svg`] ?? svgs['/src/assets/github.svg']) as string;

const rendered = className
	? svgContent.replace(/<svg\s/, `<svg class="${className}" `)
	: svgContent;
---

<Fragment set:html={rendered} />
