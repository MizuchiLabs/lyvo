---
import { ExternalLink } from '@lucide/astro';
import RepoIcon from '@/components/base/RepoIcon.astro';
import SocialIcon from '@/components/base/SocialIcon.astro';
import config from 'virtual:lyvo-config';
import { getProvider } from '@/lib/repo';

interface Props {
	repoURL?: string;
}

const { repoURL = config.repo?.url } = Astro.props;

const extraLinks = config.extraLinks;
const repoType = getProvider(repoURL);
const socialLinks = config.socials;
---

<div class="mt-auto p-4">
	{
		extraLinks && extraLinks.length > 0 && (
			<div class="mb-4 flex flex-col gap-1">
				{extraLinks.map((link) => (
					<a
						href={link.href}
						target="_blank"
						rel="noreferrer"
						class="flex items-center justify-between rounded-md p-2 text-xs text-muted-foreground transition-colors hover:bg-muted/50 hover:text-foreground"
					>
						{link.title}
						<ExternalLink size={12} class="opacity-50" />
					</a>
				))}
			</div>
		)
	}

	<div class="h-px w-full bg-border/40"></div>
	<div class="mt-4 flex items-center justify-between">
		<div class="flex items-center gap-1">
			{
				repoURL && (
					<a
						href={repoURL}
						target="_blank"
						rel="noreferrer"
						class="rounded-md p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
						title={`View on ${repoType}`}
					>
						<RepoIcon class="size-5 dark:invert" />
						<span class="sr-only">{repoType}</span>
					</a>
				)
			}

			{
				Object.entries(socialLinks).map(([platform, url]) => {
					if (!url) return null;
					return (
						<a
							href={url}
							target="_blank"
							rel="noreferrer"
							class="rounded-md p-2 text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
							title={platform.charAt(0).toUpperCase() + platform.slice(1)}
						>
							<SocialIcon platform={platform} className="size-5 dark:invert" />
							<span class="sr-only">{platform}</span>
						</a>
					);
				})
			}
		</div>
	</div>
</div>
