---
import { TextAlignStart } from '@lucide/astro';
interface Props {
	headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
	filteredHeadings.length > 0 && (
		<div class="toc-container relative z-10 text-muted-foreground select-none">
			<p class="mb-2 flex items-center gap-2 text-foreground">
				<TextAlignStart size={16} />
				On this page
			</p>
			<div class="relative flex px-2">
				<div class="toc-mask pointer-events-none absolute top-0 left-1 h-full w-10">
					<div class="absolute inset-0 h-full w-full bg-border" />
					<div class="toc-indicator absolute left-0 w-full bg-foreground transition-all duration-300 ease-out" />
				</div>

				<ul class="toc-links relative flex w-full flex-col pl-3 text-sm">
					{filteredHeadings.map((heading) => {
						const offset = heading.depth >= 3 ? 12 : 0;
						return (
							<li
								style={`padding-left: ${offset}px`}
								class="transition-colors duration-150 ease-out"
							>
								<a
									href={`#${heading.slug}`}
									data-id={heading.slug}
									class="toc-link block py-1.5 pr-2 text-muted-foreground no-underline transition-colors hover:text-foreground"
								>
									{heading.text}
								</a>
							</li>
						);
					})}
				</ul>
			</div>
		</div>
	)
}

<script>
	function buildRoundedPath(points: { x: number; y: number }[], radius: number) {
		if (points.length === 0) return '';
		if (points.length === 1) return `M ${points[0].x} ${points[0].y}`;

		const commands = [`M ${points[0].x} ${points[0].y}`];

		for (let i = 1; i < points.length; i++) {
			const point = points[i];
			const prev = points[i - 1];

			if (i === points.length - 1) {
				commands.push(` L ${point.x} ${point.y}`);
				continue;
			}

			const next = points[i + 1];
			const prevVecX = point.x - prev.x;
			const prevVecY = point.y - prev.y;
			const nextVecX = next.x - point.x;
			const nextVecY = next.y - point.y;
			const prevLen = Math.hypot(prevVecX, prevVecY);
			const nextLen = Math.hypot(nextVecX, nextVecY);

			if (prevLen === 0 || nextLen === 0) {
				commands.push(` L ${point.x} ${point.y}`);
				continue;
			}

			const prevDirX = prevVecX / prevLen;
			const prevDirY = prevVecY / prevLen;
			const nextDirX = nextVecX / nextLen;
			const nextDirY = nextVecY / nextLen;
			const dot = prevDirX * nextDirX + prevDirY * nextDirY;

			if (Math.abs(dot) > 0.999) {
				commands.push(` L ${point.x} ${point.y}`);
				continue;
			}

			const cornerRadius = Math.min(radius, prevLen / 2, nextLen / 2);
			const entryX = point.x - prevDirX * cornerRadius;
			const entryY = point.y - prevDirY * cornerRadius;
			const exitX = point.x + nextDirX * cornerRadius;
			const exitY = point.y + nextDirY * cornerRadius;

			commands.push(` L ${entryX} ${entryY}`);
			commands.push(` Q ${point.x} ${point.y} ${exitX} ${exitY}`);
		}

		return commands.join('');
	}

	function updateLayout() {
		const linksWrapper = document.querySelector('.toc-links') as HTMLElement | null;
		const maskElement = document.querySelector('.toc-mask') as HTMLElement | null;
		if (!linksWrapper || !maskElement) return;

		const links = linksWrapper.querySelectorAll('.toc-link');
		const points: { x: number; y: number }[] = [];
		let maxW = 0;
		const strokeWidth = 1.5;
		const halfStroke = strokeWidth / 2;

		links.forEach((link) => {
			const li = link.parentElement;
			if (!li) return;
			const paddingLeft = parseFloat(li.style.paddingLeft) || 0;
			const x = paddingLeft + halfStroke;

			const style = window.getComputedStyle(link);
			const paddingTop = parseFloat(style.paddingTop) || 0;
			const paddingBottom = parseFloat(style.paddingBottom) || 0;

			const linkEl = link as HTMLElement;
			const top = linkEl.offsetTop + paddingTop;
			const bottom = linkEl.offsetTop + linkEl.offsetHeight - paddingBottom;

			points.push({ x, y: top });
			points.push({ x, y: bottom });

			maxW = Math.max(maxW, x + halfStroke);
		});

		const svgPath = buildRoundedPath(points, 4);
		const svgWidth = Math.max(40, maxW + 10);
		const lineHeight = linksWrapper.scrollHeight;

		const svgData = `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 ${svgWidth} ${lineHeight}' width='${svgWidth}' height='${lineHeight}' preserveAspectRatio='none'><path d='${svgPath}' stroke='black' stroke-width='${strokeWidth}' fill='none'/></svg>`;
		const encodedSvg = `url("data:image/svg+xml,${encodeURIComponent(svgData)}")`;

		maskElement.style.maskImage = encodedSvg;
		maskElement.style.maskRepeat = 'no-repeat';
		maskElement.style.maskPosition = 'left top';
		maskElement.style.maskSize = '100% 100%';
	}

	function initScrollspy() {
		const headings = document.querySelectorAll('article h2, article h3');
		if (!headings.length) return;

		const mainScrollArea = document.querySelector('#main-scroll-area');
		const indicator = document.querySelector('.toc-indicator') as HTMLElement | null;
		if (!mainScrollArea) return;

		updateLayout();
		window.addEventListener('resize', updateLayout);

		let activeState = '';

		function updateActive() {
			if (!mainScrollArea) return;
			const viewportHeight = mainScrollArea.clientHeight;
			const scrollHeight = mainScrollArea.scrollHeight;
			const scrollY = mainScrollArea.scrollTop;
			const containerBounds = mainScrollArea.getBoundingClientRect();

			let activeIds: string[] = [];
			const headingElements = Array.from(headings);

			const viewTop = 80;
			const viewBottom = viewportHeight - 80;

			for (let i = 0; i < headingElements.length; i++) {
				const current = headingElements[i];
				const next = headingElements[i + 1];

				const currentTop = current.getBoundingClientRect().top - containerBounds.top;
				const nextTop = next
					? next.getBoundingClientRect().top - containerBounds.top
					: scrollHeight;

				if (currentTop < viewBottom && nextTop > viewTop) {
					const id = current.getAttribute('id');
					if (id) activeIds.push(id);
				}
			}

			const scrolledBottom = scrollY + viewportHeight;
			if (scrolledBottom >= scrollHeight - 20 && activeIds.length === 0) {
				const last = headingElements[headingElements.length - 1];
				if (last) activeIds.push(last.getAttribute('id') || '');
			}

			if (scrollY < 50 && activeIds.length === 0 && headingElements.length > 0) {
				activeIds.push(headingElements[0].getAttribute('id') || '');
			}

			const newState = activeIds.join(',');
			if (newState !== activeState) {
				activeState = newState;
				updateToc(activeIds);
			}
		}

		mainScrollArea.addEventListener('scroll', updateActive, { passive: true });

		function updateToc(targetIds: string[]) {
			if (!targetIds.length || !indicator) return;

			document.querySelectorAll('.toc-link').forEach((link) => {
				link.classList.remove('text-foreground', 'font-medium');
				link.classList.add('text-muted-foreground');
			});

			const activeLinks = targetIds
				.map((id) => document.querySelector(`.toc-link[data-id="${id}"]`) as HTMLElement)
				.filter(Boolean);

			if (activeLinks.length > 0) {
				activeLinks.forEach((link) => {
					link.classList.remove('text-muted-foreground');
					link.classList.add('text-foreground', 'font-medium');
				});

				const firstLink = activeLinks[0];
				const lastLink = activeLinks[activeLinks.length - 1];

				const firstStyle = window.getComputedStyle(firstLink);
				const firstPaddingTop = parseFloat(firstStyle.paddingTop) || 0;

				const lastStyle = window.getComputedStyle(lastLink);
				const lastPaddingBottom = parseFloat(lastStyle.paddingBottom) || 0;

				const top = firstLink.offsetTop + firstPaddingTop;
				const bottom = lastLink.offsetTop + lastLink.offsetHeight - lastPaddingBottom;
				const height = bottom - top;

				indicator.style.top = `${top}px`;
				indicator.style.height = `${height}px`;
			}
		}

		updateActive();
	}

	initScrollspy();
	document.addEventListener('astro:page-load', () => {
		initScrollspy();
	});
</script>
