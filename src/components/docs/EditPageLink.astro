---
import { Pencil } from '@lucide/astro';

// Helper function to build the correct edit URL based on the platform
function getEditUrl(filePath: string, branch: string, repoUrl: string, repoType: string) {
	// Strip trailing slashes to prevent double slashes in the final URL
	const base = repoUrl.replace(/\/$/, '');
	const path = filePath.startsWith('/') ? filePath.slice(1) : filePath;

	switch (repoType) {
		case 'github':
			return `${base}/edit/${branch}/${path}`;
		case 'gitlab':
			// GitLab uses /-/ in its tree/edit URLs
			return `${base}/-/edit/${branch}/${path}`;
		case 'gitea':
			// Gitea uses /_edit/
			return `${base}/_edit/${branch}/${path}`;
		default:
			return `${base}/edit/${branch}/${path}`;
	}
}

interface Props {
	filePath?: string;
	branch?: string; // Defaults to "main"
	repoUrl?: string;
	repoType?: string; // github, gitlab, gitea
}

const {
	filePath,
	branch = 'main',
	repoUrl = 'https://github.com/mizuchilabs/lyvo',
	repoType = 'github'
} = Astro.props;

const showLink = Boolean(filePath && repoUrl && repoType);
const editUrl =
	showLink && filePath && repoUrl ? getEditUrl(filePath, branch, repoUrl, repoType) : '';
---

{
	showLink && (
		<a
			href={editUrl}
			target="_blank"
			rel="noreferrer"
			class="hidden items-center gap-2 rounded-lg px-4 py-2 text-sm text-muted-foreground transition-colors hover:bg-muted/30 hover:text-foreground sm:inline-flex"
		>
			<Pencil size={14} />
			<span>Edit page</span>
		</a>
	)
}
