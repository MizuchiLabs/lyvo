---
import { Pencil } from '@lucide/astro';
import config from 'virtual:lyvo-config';
import { getProviderFromUrl } from '@/lib/repo';

// Helper function to build the correct edit URL based on the platform
function getEditUrl(filePath: string, branch: string, repoUrl: string) {
	// Strip trailing slashes to prevent double slashes in the final URL
	const base = repoUrl.replace(/\/$/, '');
	const path = filePath.startsWith('/') ? filePath.slice(1) : filePath;
	const repoType = getProviderFromUrl(repoUrl);

	switch (repoType) {
		case 'github':
			return `${base}/edit/${branch}/${path}`;
		case 'gitlab':
			// GitLab uses /-/ in its tree/edit URLs
			return `${base}/-/edit/${branch}/${path}`;
		case 'gitea':
		case 'forgejo':
			// Gitea uses /_edit/
			return `${base}/_edit/${branch}/${path}`;
		default:
			return `${base}/edit/${branch}/${path}`;
	}
}

interface Props {
	filePath?: string;
	branch?: string;
	repoUrl?: string;
}

const {
	filePath,
	branch = config.repo?.branch || 'main',
	repoUrl = config.repo?.url
} = Astro.props;

const showLink = Boolean(filePath && repoUrl);
const editUrl = showLink && filePath && repoUrl ? getEditUrl(filePath, branch, repoUrl) : '';
---

{
	showLink && (
		<a
			href={editUrl}
			target="_blank"
			rel="noreferrer"
			class="hidden items-center gap-2 rounded-lg px-4 py-2 text-sm text-muted-foreground transition-colors hover:bg-muted/30 hover:text-foreground sm:inline-flex"
		>
			<Pencil size={14} />
			<span>Edit page</span>
		</a>
	)
}
