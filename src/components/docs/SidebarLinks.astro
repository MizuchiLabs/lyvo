---
import { cn } from '@/lib/utils';
import { ChevronRight, Webhook } from '@lucide/astro';
import { getDocsHierarchy } from '@/lib/docs';
import { tryReadOpenAPIModel } from '@/lib/openapi/model';

const methodClassMap = {
	get: 'text-emerald-600 dark:text-emerald-400 bg-emerald-500/10 border-emerald-500/20',
	post: 'text-blue-600 dark:text-blue-400 bg-blue-500/10 border-blue-500/20',
	put: 'text-amber-600 dark:text-amber-400 bg-amber-500/10 border-amber-500/20',
	patch: 'text-yellow-600 dark:text-yellow-300 bg-yellow-500/10 border-yellow-500/20',
	delete: 'text-rose-600 dark:text-rose-400 bg-rose-500/10 border-rose-500/20',
	head: 'text-violet-600 dark:text-violet-300 bg-violet-500/10 border-violet-500/20',
	options: 'text-cyan-600 dark:text-cyan-400 bg-cyan-500/10 border-cyan-500/20',
	trace: 'text-fuchsia-600 dark:text-fuchsia-400 bg-fuchsia-500/10 border-fuchsia-500/20'
} as const;

// Fetch categorized and ordered hierarchy from library function
const { topLevelItems } = await getDocsHierarchy();

const model = await tryReadOpenAPIModel();
const apiGroups = model?.navigation ?? [];

const currentPath = Astro.url.pathname;
const activeMode = currentPath.startsWith('/api') ? 'api' : 'docs';
---

<div class="no-scrollbar flex-1 overflow-y-auto px-4">
	<div class="flex flex-col gap-1 pb-4">
		{
			activeMode === 'api'
				? apiGroups.map((item) => {
						const isGroupActive = item.items.some((endpoint) => {
							const href = `/api/${endpoint.slug}`;
							return currentPath === href || currentPath === href + '/';
						});

						return (
							<div class="pb-1">
								<details class="group" open={isGroupActive}>
									<summary
										class={cn(
											'flex cursor-pointer list-none items-center justify-between rounded-md px-2 py-1.5 text-sm font-semibold transition-colors select-none [&::-webkit-details-marker]:hidden',
											isGroupActive
												? 'text-foreground'
												: 'text-muted-foreground hover:bg-muted/50 hover:text-foreground'
										)}
									>
										{item.title}
										<ChevronRight
											class="opacity-50 transition-transform group-open:rotate-90"
											size={16}
										/>
									</summary>
									<div class="mt-1 ml-4 flex flex-col gap-1 border-l border-border/70 pl-2 text-sm">
										{item.items.map((endpoint) => {
											const href = `/api/${endpoint.slug}`;
											const isActive =
												currentPath === href || currentPath === href + '/';

											return (
												<a
													href={href}
													class={cn(
														'group flex w-full items-center justify-between gap-2 rounded-md border border-transparent px-2 py-1.5 text-sm transition-colors select-none',
														isActive
															? 'bg-accent/50 font-medium text-foreground'
															: 'text-muted-foreground hover:bg-muted/50 hover:text-foreground'
													)}
												>
													<span class="line-clamp-2 flex-1 overflow-hidden leading-5 text-ellipsis">
														{endpoint.label}
													</span>

													{endpoint.isWebhook ? (
														<span class="ms-auto inline-flex shrink-0 items-center gap-1 rounded border border-fuchsia-500/30 bg-fuchsia-500/10 px-1 py-0 text-[10px] leading-4 font-semibold text-fuchsia-600 uppercase dark:text-fuchsia-300">
															<Webhook size={10} />
															{endpoint.method}
														</span>
													) : (
														<span
															class={cn(
																'ms-auto shrink-0 rounded border px-1 py-0 text-[10px] leading-4 font-semibold uppercase',
																methodClassMap[endpoint.method]
															)}
														>
															{endpoint.method}
														</span>
													)}
												</a>
											);
										})}
									</div>
								</details>
							</div>
						);
					})
				: topLevelItems.map((item) => {
						if (item.type === 'doc') {
							const href = `/docs/${item.doc.id}`;
							const isActive = currentPath === href || currentPath === href + '/';
							return (
								<a
									href={href}
									class={cn(
										'group flex w-full items-center rounded-md border border-transparent px-2 py-1.5 text-sm font-semibold transition-colors select-none',
										isActive
											? 'text-foreground'
											: 'text-muted-foreground hover:bg-muted/50 hover:text-foreground'
									)}
								>
									{item.title}
								</a>
							);
						}

						const isCategoryActive = item.items.some((doc) => {
							const href = `/docs/${doc.id}`;
							return currentPath === href || currentPath === href + '/';
						});

						return (
							<div class="pb-1">
								<details class="group" open>
									<summary
										class={cn(
											'flex cursor-pointer list-none items-center justify-between rounded-md px-2 py-1.5 text-sm font-semibold transition-colors select-none [&::-webkit-details-marker]:hidden',
											isCategoryActive
												? 'text-foreground'
												: 'text-muted-foreground hover:bg-muted/50 hover:text-foreground'
										)}
									>
										{item.title}
										<ChevronRight
											class="opacity-50 transition-transform group-open:rotate-90"
											size={16}
										/>
									</summary>
									<div class="mt-1 ml-4 flex flex-col gap-1 border-l border-border/70 pl-2 text-sm">
										{item.items.map((doc) => {
											const href = `/docs/${doc.id}`;
											const isActive =
												currentPath === href || currentPath === href + '/';
											return (
												<a
													href={href}
													class={cn(
														'group flex w-full items-center rounded-md border border-transparent px-2 py-1.5 text-sm transition-colors select-none',
														isActive
															? 'bg-accent/50 font-medium text-foreground'
															: 'text-muted-foreground hover:bg-muted/50 hover:text-foreground'
													)}
												>
													{doc.data.title}
												</a>
											);
										})}
									</div>
								</details>
							</div>
						);
					})
		}
	</div>
</div>
