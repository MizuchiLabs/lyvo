---
import { SITE } from '@/config';
import { Pencil } from '@lucide/astro';

// Helper function to build the correct edit URL based on the platform
function getEditUrl(filePath: string, branch: string = 'main') {
	// Strip trailing slashes to prevent double slashes in the final URL
	const base = SITE.repo.url.replace(/\/$/, '');
	const path = filePath.startsWith('/') ? filePath.slice(1) : filePath;

	switch (SITE.repo.type) {
		case 'github':
			return `${base}/edit/${branch}/${path}`;
		case 'gitlab':
			// GitLab uses /-/ in its tree/edit URLs
			return `${base}/-/edit/${branch}/${path}`;
		case 'gitea':
			// Gitea uses /_edit/
			return `${base}/_edit/${branch}/${path}`;
		default:
			return `${base}/edit/${branch}/${path}`;
	}
}

interface Props {
	filePath?: string;
	branch?: string; // Defaults to "main"
}

const { filePath, branch = 'main' } = Astro.props;
const showLink = Boolean(filePath && SITE.repo.url && SITE.repo.type);
const editUrl = showLink && filePath ? getEditUrl(filePath, branch) : '';
---

{
	showLink && (
		<a
			href={editUrl}
			target="_blank"
			rel="noreferrer"
			class="hidden items-center gap-2 rounded-lg px-4 py-2 text-sm text-muted-foreground transition-colors hover:bg-muted/30 hover:text-foreground sm:inline-flex"
		>
			<Pencil size={14} />
			<span>Edit page</span>
		</a>
	)
}
