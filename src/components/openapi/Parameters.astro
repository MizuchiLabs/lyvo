---
import type { OpenAPIParameter } from '@/lib/openapi/types';

interface Props {
	parameters: OpenAPIParameter[];
}

const { parameters } = Astro.props;

if (!parameters || parameters.length === 0) return null;

const typeColor = {
	string: 'text-emerald-600 dark:text-emerald-400',
	integer: 'text-blue-600 dark:text-blue-400',
	number: 'text-blue-600 dark:text-blue-400',
	boolean: 'text-rose-600 dark:text-rose-400',
	array: 'text-amber-600 dark:text-amber-400',
	object: 'text-fuchsia-600 dark:text-fuchsia-400',
	any: 'text-muted-foreground'
} as const;

function formatExample(value: unknown): string {
	if (typeof value === 'string') return value;

	try {
		return JSON.stringify(value);
	} catch {
		return String(value);
	}
}

function getBaseType(type?: string): keyof typeof typeColor {
	if (!type) return 'any';
	const normalized = type.split('|')[0]?.trim();
	if (!normalized) return 'any';
	if (normalized in typeColor) return normalized as keyof typeof typeColor;
	return 'any';
}

const parameterGroups = {
	path: parameters.filter((parameter) => parameter.in === 'path'),
	query: parameters.filter((parameter) => parameter.in === 'query'),
	header: parameters.filter((parameter) => parameter.in === 'header'),
	cookie: parameters.filter((parameter) => parameter.in === 'cookie')
};

const groupOrder: Array<keyof typeof parameterGroups> = ['path', 'query', 'header', 'cookie'];
---

<>
	{
		groupOrder.map((groupKey) => {
			const groupParams = parameterGroups[groupKey];
			if (groupParams.length === 0) return null;

			return (
				<section>
					<h2 class="mb-4 text-xl font-semibold tracking-tight capitalize">
						{groupKey} Parameters
					</h2>
					<div class="divide-y divide-border border-y border-border">
						{groupParams.map((parameter: OpenAPIParameter) => (
							<div class="space-y-2 py-4">
								<div class="flex flex-wrap items-center gap-2">
									<span class="text-sm font-semibold text-foreground">
										{parameter.name}
										{!parameter.required && (
											<span class="font-normal text-muted-foreground/75">
												?
											</span>
										)}
									</span>
									{parameter.type && (
										<span
											class:list={[
												'font-mono text-[11px] font-medium',
												typeColor[getBaseType(parameter.type)]
											]}
										>
											{parameter.type}
											{parameter.format ? ` <${parameter.format}>` : ''}
										</span>
									)}
									{parameter.required && (
										<span class="rounded-md border border-amber-500/30 bg-amber-500/5 px-2 py-0.5 text-[10px] font-medium tracking-wider text-amber-600 uppercase dark:text-amber-300">
											required
										</span>
									)}
								</div>
								{parameter.description && (
									<p class="text-sm leading-relaxed text-muted-foreground">
										{parameter.description}
									</p>
								)}
								<div class="flex flex-wrap gap-2">
									{parameter.example !== undefined && (
										<span class="rounded-md border border-border bg-muted/30 px-2 py-1 text-xs font-medium text-muted-foreground">
											Example {formatExample(parameter.example)}
										</span>
									)}
									{parameter.examples && parameter.examples.length > 1 && (
										<span class="rounded-md border border-border bg-muted/30 px-2 py-1 text-xs font-medium text-muted-foreground">
											{parameter.examples.length} examples
										</span>
									)}
								</div>
							</div>
						))}
					</div>
				</section>
			);
		})
	}
</>
