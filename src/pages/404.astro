---
import { Button } from '@/components/ui/button.tsx';
import { House } from '@lucide/astro';
import Layout from '@/layouts/Layout.astro';
---

<Layout>
	<main class="relative flex flex-1 flex-col items-center justify-center overflow-hidden">
		<!-- Background effects -->
		<div
			class="absolute inset-0 -z-10 h-full w-full bg-background [background:radial-gradient(125%_125%_at_50%_10%,#fff_40%,#63e_100%)] dark:[background:radial-gradient(125%_125%_at_50%_10%,#000_40%,#63e_100%)]"
		>
		</div>

		<div
			class="container mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center md:px-6 md:py-32"
		>
			<h1
				class="mb-4 text-6xl font-extrabold tracking-tight text-balance text-foreground sm:text-7xl md:text-8xl lg:text-9xl"
			>
				<span
					class="bg-linear-to-r from-indigo-500 to-cyan-500 bg-clip-text text-transparent dark:from-indigo-400 dark:to-cyan-400"
					>404</span
				>
			</h1>

			<h2 class="mb-6 text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
				Page not found
			</h2>

			<p class="mb-10 max-w-2xl text-lg text-balance text-muted-foreground sm:text-xl">
				Sorry, we couldn't find the page you're looking for. It might have been moved or
				doesn't exist.
			</p>

			<div
				class="flex w-full flex-col items-center justify-center gap-4 sm:w-auto sm:flex-row"
			>
				<a href="/" class="w-full sm:w-auto">
					<Button
						size="lg"
						className="w-full gap-2 rounded-full px-6 font-medium sm:w-auto"
					>
						<House size={16} /> Back to Home
					</Button>
				</a>
			</div>
		</div>
	</main>
</Layout>
