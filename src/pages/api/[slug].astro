---
import ApiLayout from '@/layouts/ApiLayout.astro';
import {
	getOpenAPIOperationBySlug,
	getOpenAPIWebhookBySlug,
	readOpenAPIModel
} from '@/lib/openapi/model';
import type {
	HttpMethod,
	OpenAPIMediaType,
	OpenAPIParameter,
	OpenAPIResponse,
	OpenAPISecurityRequirement,
	OpenAPISnippet
} from '@/lib/openapi/types';
import Tabs from '@/components/Tabs.astro';
import TabItem from '@/components/TabItem.astro';
import CodeBlock from '@/components/CodeBlock.astro';

const model = readOpenAPIModel();

export async function getStaticPaths() {
	const model = readOpenAPIModel();

	return [...model.operations, ...model.webhooks].map((endpoint) => ({
		params: { slug: endpoint.slug }
	}));
}

const { slug } = Astro.params;
const operation = getOpenAPIOperationBySlug(model, slug ?? '');
const webhook = operation ? null : getOpenAPIWebhookBySlug(model, slug ?? '');
const endpoint = operation ?? webhook;

if (!endpoint) {
	return Astro.redirect('/404');
}

const isWebhook = webhook !== null;
const methodLabel = endpoint.method.toUpperCase();
const requestBody = endpoint.requestBody;

const parameterGroups = {
	path: endpoint.parameters.filter((parameter) => parameter.in === 'path'),
	query: endpoint.parameters.filter((parameter) => parameter.in === 'query'),
	header: endpoint.parameters.filter((parameter) => parameter.in === 'header'),
	cookie: endpoint.parameters.filter((parameter) => parameter.in === 'cookie')
};

const groupOrder: Array<keyof typeof parameterGroups> = ['path', 'query', 'header', 'cookie'];

const methodColor = {
	get: 'text-emerald-600 dark:text-emerald-400 border-emerald-500/30 bg-emerald-500/5',
	post: 'text-blue-600 dark:text-blue-400 border-blue-500/30 bg-blue-500/5',
	put: 'text-amber-600 dark:text-amber-400 border-amber-500/30 bg-amber-500/5',
	patch: 'text-yellow-600 dark:text-yellow-300 border-yellow-500/30 bg-yellow-500/5',
	delete: 'text-rose-600 dark:text-rose-400 border-rose-500/30 bg-rose-500/5',
	head: 'text-violet-600 dark:text-violet-300 border-violet-500/30 bg-violet-500/5',
	options: 'text-cyan-600 dark:text-cyan-400 border-cyan-500/30 bg-cyan-500/5',
	trace: 'text-fuchsia-600 dark:text-fuchsia-400 border-fuchsia-500/30 bg-fuchsia-500/5'
} as const;

function formatJson(value: unknown): string {
	if (value === undefined) return '';

	try {
		return JSON.stringify(value, null, 2);
	} catch {
		return String(value);
	}
}

function securityLabel(requirement: OpenAPISecurityRequirement): string {
	if (requirement.type === 'http') {
		return `${requirement.name} (${requirement.scheme ?? 'http'})`;
	}

	if (requirement.type === 'apiKey') {
		return `${requirement.name} (apiKey in ${requirement.in ?? 'unknown'})`;
	}

	return `${requirement.name} (${requirement.type})`;
}

function responseTone(status: string): string {
	const code = Number.parseInt(status, 10);
	if (Number.isNaN(code)) return 'text-muted-foreground';
	if (code >= 200 && code < 300) return 'text-emerald-600 dark:text-emerald-400';
	if (code >= 300 && code < 400) return 'text-blue-600 dark:text-blue-400';
	if (code >= 400 && code < 500) return 'text-amber-600 dark:text-amber-300';
	if (code >= 500) return 'text-rose-600 dark:text-rose-400';
	return 'text-muted-foreground';
}
---

<ApiLayout title={endpoint.title} description={endpoint.description ?? endpoint.summary}>
	<div class="space-y-8">
		<section class="rounded-xl border border-border/70 bg-card p-4 sm:p-5">
			<div class="flex flex-wrap items-center gap-3">
				<span
					class:list={[
						'rounded-md border px-2 py-1 text-xs font-semibold tracking-wide uppercase',
						methodColor[endpoint.method as HttpMethod]
					]}
				>
					{methodLabel}
				</span>
				<code
					class="min-w-0 flex-1 overflow-auto rounded-md bg-muted/50 px-3 py-1.5 text-sm"
				>
					{endpoint.path}
				</code>
				{
					isWebhook && (
						<span class="rounded-md border border-fuchsia-500/30 bg-fuchsia-500/10 px-2 py-1 text-xs font-semibold text-fuchsia-600 uppercase dark:text-fuchsia-300">
							Webhook
						</span>
					)
				}
			</div>

			{
				endpoint.summary && (
					<p class="mt-4 text-sm text-muted-foreground">{endpoint.summary}</p>
				)
			}

			{
				endpoint.tags.length > 0 && (
					<div class="mt-4 flex flex-wrap gap-2">
						{endpoint.tags.map((tag) => (
							<span class="rounded-md border border-border px-2 py-1 text-xs text-muted-foreground">
								{tag}
							</span>
						))}
					</div>
				)
			}
		</section>

		{
			groupOrder.map((groupKey) => {
				const parameters = parameterGroups[groupKey];
				if (parameters.length === 0) return null;

				return (
					<section class="rounded-xl border border-border/70 bg-card p-4 sm:p-5">
						<h2 class="text-xl font-semibold capitalize">{groupKey} Parameters</h2>
						<div class="mt-4 space-y-4">
							{parameters.map((parameter: OpenAPIParameter) => (
								<div class="rounded-lg border border-border/70 p-3">
									<div class="flex flex-wrap items-center gap-2">
										<code class="text-sm font-semibold">{parameter.name}</code>
										{parameter.required ? (
											<span class="rounded-md border border-amber-500/30 bg-amber-500/5 px-2 py-0.5 text-xs text-amber-600 dark:text-amber-300">
												required
											</span>
										) : (
											<span class="rounded-md border border-border px-2 py-0.5 text-xs text-muted-foreground">
												optional
											</span>
										)}
									</div>
									{parameter.description && (
										<p class="mt-2 text-sm text-muted-foreground">
											{parameter.description}
										</p>
									)}
									{parameter.example !== undefined && (
										<div class="mt-3">
											<p class="mb-2 text-xs font-medium tracking-wide text-muted-foreground uppercase">
												Example
											</p>
											<CodeBlock
												code={formatJson(parameter.example)}
												lang="json"
											/>
										</div>
									)}
								</div>
							))}
						</div>
					</section>
				);
			})
		}

		{
			requestBody && (
				<section class="rounded-xl border border-border/70 bg-card p-4 sm:p-5">
					<div class="flex flex-wrap items-center gap-2">
						<h2 class="text-xl font-semibold">Request Body</h2>
						{requestBody.required && (
							<span class="rounded-md border border-amber-500/30 bg-amber-500/5 px-2 py-0.5 text-xs text-amber-600 dark:text-amber-300">
								required
							</span>
						)}
					</div>
					{requestBody.description && (
						<p class="mt-2 text-sm text-muted-foreground">{requestBody.description}</p>
					)}

					<div class="mt-4 space-y-4">
						{requestBody.content.map((item: OpenAPIMediaType) => (
							<div class="rounded-lg border border-border/70 p-3">
								<p class="text-xs font-semibold tracking-wide text-muted-foreground uppercase">
									{item.mediaType}
								</p>
								{item.example !== undefined && (
									<div class="mt-3">
										<p class="mb-2 text-xs font-medium tracking-wide text-muted-foreground uppercase">
											Example
										</p>
										<CodeBlock code={formatJson(item.example)} lang="json" />
									</div>
								)}
								{item.schema !== undefined && (
									<details class="mt-3 rounded-md border border-border/70">
										<summary class="cursor-pointer px-3 py-2 text-sm font-medium">
											Schema
										</summary>
										<div class="border-t border-border/70 px-3 py-3">
											<CodeBlock code={formatJson(item.schema)} lang="json" />
										</div>
									</details>
								)}
							</div>
						))}
					</div>
				</section>
			)
		}

		<section class="rounded-xl border border-border/70 bg-card p-4 sm:p-5">
			<h2 class="text-xl font-semibold">Responses</h2>
			<div class="mt-4 space-y-4">
				{
					endpoint.responses.map((response: OpenAPIResponse) => (
						<div class="rounded-lg border border-border/70 p-3">
							<div class="flex items-center gap-2">
								<code
									class:list={[
										'text-sm font-semibold',
										responseTone(response.status)
									]}
								>
									{response.status}
								</code>
								{response.description && (
									<p class="text-sm text-muted-foreground">
										{response.description}
									</p>
								)}
							</div>

							<div class="mt-3 space-y-3">
								{response.content.map((item: OpenAPIMediaType) => (
									<div class="rounded-md border border-border/70 p-3">
										<p class="text-xs font-semibold tracking-wide text-muted-foreground uppercase">
											{item.mediaType}
										</p>
										{item.example !== undefined && (
											<div class="mt-2">
												<p class="mb-2 text-xs font-medium tracking-wide text-muted-foreground uppercase">
													Example
												</p>
												<CodeBlock
													code={formatJson(item.example)}
													lang="json"
												/>
											</div>
										)}
										{item.schema !== undefined && (
											<details class="mt-2 rounded-md border border-border/70">
												<summary class="cursor-pointer px-3 py-2 text-sm font-medium">
													Schema
												</summary>
												<div class="border-t border-border/70 px-3 py-3">
													<CodeBlock
														code={formatJson(item.schema)}
														lang="json"
													/>
												</div>
											</details>
										)}
									</div>
								))}
							</div>
						</div>
					))
				}
			</div>
		</section>

		{
			endpoint.security.length > 0 && (
				<section class="rounded-xl border border-border/70 bg-card p-4 sm:p-5">
					<h2 class="text-xl font-semibold">Authorization</h2>
					<ul class="mt-4 space-y-2">
						{endpoint.security.map((item: OpenAPISecurityRequirement) => (
							<li class="rounded-md border border-border/70 p-3">
								<p class="text-sm font-semibold">{securityLabel(item)}</p>
								{item.description && (
									<p class="mt-1 text-sm text-muted-foreground">
										{item.description}
									</p>
								)}
								{item.scopes.length > 0 && (
									<p class="mt-2 text-xs text-muted-foreground">
										Scopes: {item.scopes.join(', ')}
									</p>
								)}
							</li>
						))}
					</ul>
				</section>
			)
		}

		<section class="rounded-xl border border-border/70 bg-card p-4 sm:p-5">
			<h2 class="text-xl font-semibold">Code Samples</h2>
			<div class="mt-4">
				<Tabs>
					{
						endpoint.snippets.map((snippet: OpenAPISnippet) => (
							<TabItem value={snippet.id} label={snippet.label}>
								<CodeBlock code={snippet.code} lang={snippet.language} />
							</TabItem>
						))
					}
				</Tabs>
			</div>
		</section>
	</div>
</ApiLayout>
