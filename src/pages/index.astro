---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/marketing/Hero.astro';
import FeaturePreview from '@/components/marketing/FeaturePreview.astro';

// Editable configs for Index page
const repoUrl = 'https://github.com/mizuchilabs/lyvo';
const repoType = 'github';
---

<Layout>
	<main
		class="relative flex h-[calc(100vh-4rem)] w-full flex-col items-center overflow-hidden bg-background"
	>
		<div class="container mx-auto flex h-full max-w-6xl flex-col items-center px-4">
			<Hero repoUrl={repoUrl} repoType={repoType} />
			<FeaturePreview />
		</div>
	</main>
</Layout>
