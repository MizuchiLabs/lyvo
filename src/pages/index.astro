---
import { Button } from '@/components/ui/button.tsx';
import { ArrowRight } from 'lucide-react';
import Layout from '@/layouts/Layout.astro';
import { SITE } from '@/config.ts';
import RepoIcon from '@/components/RepoIcon';
---

<Layout title={`${SITE.title}`}>
	<main
		class="relative flex h-[calc(100vh-4rem)] w-full flex-col items-center overflow-hidden bg-background"
	>
		<div class="container mx-auto flex h-full max-w-6xl flex-col items-center px-4">
			<!-- Hero Text Section -->
			<div class="flex flex-1 flex-col items-center justify-center pt-8 pb-4 text-center">
				<div
					class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-xs font-medium text-primary backdrop-blur-sm md:text-sm"
				>
					<span class="flex h-2 w-2 animate-pulse rounded-full bg-primary"></span>
					v{SITE.showVersion ? '1.0.0' : ''} — Open Source Documentation Template
				</div>

				<h1
					class="mb-4 text-4xl font-extrabold tracking-tighter text-foreground sm:text-6xl md:text-7xl lg:text-8xl"
				>
					Professional docs, <br />
					<span class="text-primary italic">built for developers.</span>
				</h1>

				<p class="mb-8 max-w-2xl text-base text-balance text-muted-foreground sm:text-lg">
					A structured, highly-extensible documentation framework for Astro. Focused on technical
					clarity, speed, and standard-compliant architecture.
				</p>

				<div class="flex w-full flex-col items-center gap-4 sm:w-auto sm:flex-row">
					<a href="/docs/introduction" class="w-full sm:w-auto">
						<Button size="lg" className="h-11 w-full gap-2 rounded-lg px-8 font-semibold sm:w-auto">
							Get Started <ArrowRight className="h-4 w-4" />
						</Button>
					</a>

					<a href={SITE.repo.url} target="_blank" rel="noreferrer" class="w-full sm:w-auto">
						<Button
							variant="outline"
							size="lg"
							className="h-11 w-full rounded-lg border-border bg-background/50 px-8 font-semibold backdrop-blur-sm transition-all hover:bg-accent sm:w-auto"
						>
							<RepoIcon className="mr-2 dark:invert" />
							View on {SITE.repo.type.charAt(0).toUpperCase() + SITE.repo.type.slice(1)}
						</Button>
					</a>
				</div>
			</div>

			<!-- Structural Hero Mockup - Fixed height and translated to fit -->
			<div class="relative w-full max-w-5xl translate-y-4 pb-12 sm:translate-y-8">
				<div class="relative grid grid-cols-1 gap-6 lg:grid-cols-2">
					<!-- Left Side: Source -->
					<div
						class="group relative overflow-hidden rounded-xl border border-border bg-card p-1 shadow-2xl transition-all duration-500 hover:scale-[1.01]"
					>
						<div
							class="flex h-8 items-center justify-between border-b border-border bg-muted/30 px-3"
						>
							<div class="flex gap-1.5">
								<div class="h-2.5 w-2.5 rounded-full bg-border"></div>
								<div class="h-2.5 w-2.5 rounded-full bg-border"></div>
								<div class="h-2.5 w-2.5 rounded-full bg-border"></div>
							</div>
							<span
								class="font-mono text-[9px] font-medium tracking-widest text-muted-foreground uppercase"
								>Source (MDX)</span
							>
						</div>
						<div class="p-4 font-mono text-[11px] leading-tight text-muted-foreground sm:text-xs">
							<div class="flex items-start gap-3">
								<span class="w-3 text-muted-foreground/30 select-none">1</span>
								<span class="text-primary">---</span>
							</div>
							<div class="flex items-start gap-3">
								<span class="w-3 text-muted-foreground/30 select-none">2</span>
								<span>title: <span class="text-foreground">"Introduction"</span></span>
							</div>
							<div class="flex items-start gap-3">
								<span class="w-3 text-muted-foreground/30 select-none">3</span>
								<span class="text-primary">---</span>
							</div>
							<div class="flex items-start gap-3">
								<span class="w-3 text-muted-foreground/30 select-none">4</span>
								<span class="opacity-0">.</span>
							</div>
							<div class="flex items-start gap-3">
								<span class="w-3 text-muted-foreground/30 select-none">5</span>
								<span class="text-foreground"># Getting Started</span>
							</div>
							<div class="flex items-start gap-3">
								<span class="w-3 text-muted-foreground/30 select-none">6</span>
								<span class="opacity-0">.</span>
							</div>
							<div class="flex items-start gap-3">
								<span class="w-3 text-muted-foreground/30 select-none">7</span>
								<span>Welcome to Lyvo.</span>
							</div>
							<div class="flex items-start gap-3">
								<span class="w-3 text-muted-foreground/30 select-none">8</span>
								<span>&lt;<span class="text-primary">Callout</span>&gt;</span>
							</div>
							<div class="flex items-start gap-3">
								<span class="w-3 text-muted-foreground/30 select-none">9</span>
								<span class="pl-3">Ready?</span>
							</div>
							<div class="flex items-start gap-3">
								<span class="w-3 text-muted-foreground/30 select-none">10</span>
								<span>&lt;/<span class="text-primary">Callout</span>&gt;</span>
							</div>
						</div>
					</div>

					<!-- Connection (Arrow on Desktop) -->
					<div class="absolute top-1/2 left-1/2 hidden -translate-x-1/2 -translate-y-1/2 lg:block">
						<div class="flex items-center gap-3">
							<div class="h-px w-6 bg-border"></div>
							<div class="rounded-full border border-border bg-background p-1.5 shadow-lg">
								<ArrowRight className="h-3 w-3 text-primary" />
							</div>
							<div class="h-px w-6 bg-border"></div>
						</div>
					</div>

					<!-- Right Side: Preview -->
					<div
						class="group relative hidden overflow-hidden rounded-xl border border-border bg-card p-1 shadow-2xl transition-all duration-500 hover:scale-[1.01] lg:block"
					>
						<div
							class="flex h-8 items-center justify-between border-b border-border bg-muted/30 px-3"
						>
							<div class="flex gap-1.5">
								<div class="h-2.5 w-2.5 rounded-full bg-red-500/50"></div>
								<div class="h-2.5 w-2.5 rounded-full bg-amber-500/50"></div>
								<div class="h-2.5 w-2.5 rounded-full bg-green-500/50"></div>
							</div>
							<span
								class="font-mono text-[9px] font-medium tracking-widest text-muted-foreground uppercase"
								>Live Preview</span
							>
						</div>
						<div class="bg-background p-4">
							<div class="mb-3 h-6 w-32 rounded bg-foreground/5"></div>
							<div class="mb-4 space-y-2">
								<div class="h-3 w-full rounded bg-muted/40"></div>
								<div class="h-3 w-2/3 rounded bg-muted/40"></div>
							</div>
							<div class="rounded-lg border border-primary/20 bg-primary/5 p-3">
								<div class="flex items-center gap-2">
									<div class="h-3 w-3 rounded-full bg-primary/40"></div>
									<div class="h-2.5 w-24 rounded bg-primary/20"></div>
								</div>
							</div>
							<div class="mt-4 flex gap-3">
								<div class="h-12 flex-1 rounded-lg border border-border bg-muted/20"></div>
								<div class="h-12 w-1/4 rounded-lg border border-border bg-muted/20"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>
