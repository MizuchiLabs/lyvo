---
import { render } from 'astro:content';
import Accordion from '@/components/docs/Accordion.astro';
import DocsLayout from '@/layouts/DocsLayout.astro';
import { getCollection } from 'astro:content';
import Tabs from '@/components/docs/Tabs.astro';
import TabItem from '@/components/docs/TabItem.astro';
import CodeBlock from '@/components/base/CodeBlock.astro';
import Link from '@/components/base/Link.astro';
import Table from '@/components/docs/Table.astro';
import ImageWrapper from '@/components/base/ImageWrapper.astro';
import Callout from '@/components/docs/Callout.astro';
import Steps from '@/components/docs/Steps.astro';
import Step from '@/components/docs/Step.astro';
import FileTree from '@/components/docs/FileTree.astro';
import Folder from '@/components/docs/Folder.astro';
import File from '@/components/docs/File.astro';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	return docs.map((entry) => ({
		params: { slug: entry.id },
		props: { entry }
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const components = {
	Code: CodeBlock,
	a: Link,
	table: Table,
	img: ImageWrapper,
	Callout,
	Steps,
	Step,
	Tabs,
	TabItem,
	FileTree,
	Folder,
	File,
	Accordion
};

// Build TOC
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<DocsLayout
	title={entry.data.title}
	description={entry.data.description}
	headings={filteredHeadings}
	entry={entry}
>
	<Content components={components} />
</DocsLayout>
