---
import { ScalarComponent } from '@scalar/astro';
import FloatingBackButton from '@/components/FloatingBackButton.astro';

// Editable configs for API
const openapiUrl = '/openapi.json';

if (!openapiUrl) {
	return Astro.redirect('/404');
}
---

<ScalarComponent
	configuration={{
		url: openapiUrl,
		proxyUrl: 'https://proxy.scalar.com',
		theme: 'default',
		defaultOpenAllTags: true
	}}
/>

<FloatingBackButton />
